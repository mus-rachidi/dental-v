<Window x:Class="ClinicManager.Views.Dialogs.LicenseDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="License Activation" Height="520" Width="540"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#F8FAFC">

    <Grid Margin="40">
        <StackPanel VerticalAlignment="Center">
            <!-- Header -->
            <TextBlock Text="Clinic Manager" FontSize="28" FontWeight="Bold" 
                       Foreground="#2563EB" HorizontalAlignment="Center" Margin="0,0,0,8"
                       FontFamily="Segoe UI" />
            <TextBlock Text="License Activation" FontSize="14" Foreground="#64748B"
                       HorizontalAlignment="Center" Margin="0,0,0,32" FontFamily="Segoe UI" />

            <!-- Machine ID -->
            <TextBlock Text="Your Machine ID:" FontSize="12" Foreground="#64748B" 
                       FontWeight="SemiBold" Margin="0,0,0,6" FontFamily="Segoe UI" />
            <DockPanel Margin="0,0,0,4">
                <Button x:Name="CopyButton" DockPanel.Dock="Right" Content="Copy" 
                        Click="CopyMachineId_Click" Margin="8,0,0,0"
                        Background="#2563EB" Foreground="White" FontSize="12" FontWeight="SemiBold"
                        Padding="16,8" Cursor="Hand" FontFamily="Segoe UI" BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8" 
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Border Background="#F1F5F9" CornerRadius="8" Padding="12,10">
                    <TextBox x:Name="MachineIdText" IsReadOnly="True" Background="Transparent" 
                             BorderThickness="0" FontFamily="Consolas" FontSize="12"
                             Foreground="#0F172A" />
                </Border>
            </DockPanel>
            <TextBlock Text="Click Copy, then send this ID to get your license key" FontSize="11" 
                       Foreground="#94A3B8" Margin="0,0,0,24" FontFamily="Segoe UI" />

            <!-- License Key Input -->
            <TextBlock Text="License Key:" FontSize="12" Foreground="#64748B" 
                       FontWeight="SemiBold" Margin="0,0,0,6" FontFamily="Segoe UI" />
            <Border Background="White" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,0,16">
                <TextBox x:Name="LicenseKeyInput" Padding="12,10" BorderThickness="0" FontSize="14"
                         FontFamily="Consolas" Foreground="#0F172A" CharacterCasing="Upper" />
            </Border>

            <!-- Name Input -->
            <TextBlock Text="Licensed To (Name or Clinic):" FontSize="12" Foreground="#64748B" 
                       FontWeight="SemiBold" Margin="0,0,0,6" FontFamily="Segoe UI" />
            <Border Background="White" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,0,24">
                <TextBox x:Name="LicensedToInput" Padding="12,10" BorderThickness="0" FontSize="13"
                         FontFamily="Segoe UI" Foreground="#0F172A" />
            </Border>

            <!-- Error message -->
            <TextBlock x:Name="ErrorText" Foreground="#DC2626" FontSize="12" Margin="0,0,0,12"
                       Visibility="Collapsed" HorizontalAlignment="Center" FontFamily="Segoe UI"
                       TextWrapping="Wrap" />

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="ActivateButton" Content="Activate" Click="ActivateButton_Click"
                        Background="#2563EB" Foreground="White" FontSize="14" FontWeight="SemiBold"
                        Padding="32,10" Cursor="Hand" FontFamily="Segoe UI">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8" 
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Content="Exit" Click="ExitButton_Click" Margin="12,0,0,0"
                        Background="Transparent" Foreground="#64748B" FontSize="14"
                        Padding="24,10" Cursor="Hand" FontFamily="Segoe UI" BorderThickness="0" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
