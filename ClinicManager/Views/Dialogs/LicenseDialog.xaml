<Window x:Class="ClinicManager.Views.Dialogs.LicenseDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="License Activation" Height="560" Width="520"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#ECE9D8" WindowStyle="SingleBorderWindow">

    <Border Background="White" BorderBrush="#ACA899" BorderThickness="1"
            Margin="0">
        <Grid Margin="24,20">
            <StackPanel VerticalAlignment="Center" Margin="0,0,0,0">
                <!-- Logo -->
                <Border Width="48" Height="48" Background="#0054E3" 
                        HorizontalAlignment="Center" Margin="0,0,0,12"
                        BorderBrush="#ACA899" BorderThickness="1">
                    <TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets" FontSize="22"
                               Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock Text="Clinic Manager" FontSize="18" FontWeight="Bold" 
                           Foreground="#000000" HorizontalAlignment="Center" FontFamily="Tahoma" />
                <TextBlock Text="Activate your license to continue" FontSize="11" Foreground="#000000"
                           HorizontalAlignment="Center" Margin="0,4,0,20" FontFamily="Tahoma" />

                <!-- Machine ID -->
                <TextBlock Text="MACHINE ID" FontSize="10" Foreground="#000000" 
                           FontWeight="Bold" Margin="0,0,0,4" FontFamily="Tahoma" />
                <DockPanel Margin="0,0,0,4">
                    <Button x:Name="CopyButton" DockPanel.Dock="Right" Content="Copy" 
                            Click="CopyMachineId_Click" Margin="6,0,0,0"
                            Background="#ECE9D8" Foreground="#000000" FontSize="11"
                            Padding="12,6" Cursor="Hand" FontFamily="Tahoma" BorderThickness="1"
                            BorderBrush="#ACA899" Height="28" />
                    <Border Background="White" Padding="8,6" BorderBrush="#ACA899" BorderThickness="1">
                        <TextBox x:Name="MachineIdText" IsReadOnly="True" Background="Transparent" 
                                 BorderThickness="0" FontFamily="Consolas" FontSize="11"
                                 Foreground="#000000" VerticalAlignment="Center" />
                    </Border>
                </DockPanel>
                <TextBlock Text="Send this ID to get your license key" FontSize="10" 
                           Foreground="#000000" Margin="0,0,0,16" FontFamily="Tahoma" />

                <!-- License Key -->
                <TextBlock Text="LICENSE KEY" FontSize="10" Foreground="#000000" 
                           FontWeight="Bold" Margin="0,0,0,4" FontFamily="Tahoma" />
                <Border Background="White" BorderBrush="#ACA899" BorderThickness="1" Margin="0,0,0,12">
                    <TextBox x:Name="LicenseKeyInput" Padding="8,8" BorderThickness="0" FontSize="12"
                             FontFamily="Consolas" Foreground="#000000" Background="Transparent"
                             CharacterCasing="Upper" />
                </Border>

                <!-- Name -->
                <TextBlock Text="LICENSED TO" FontSize="10" Foreground="#000000" 
                           FontWeight="Bold" Margin="0,0,0,4" FontFamily="Tahoma" />
                <Border Background="White" BorderBrush="#ACA899" BorderThickness="1" Margin="0,0,0,20">
                    <TextBox x:Name="LicensedToInput" Padding="8,8" BorderThickness="0" FontSize="12"
                             FontFamily="Tahoma" Foreground="#000000" Background="Transparent" />
                </Border>

                <!-- Error -->
                <TextBlock x:Name="ErrorText" Foreground="#B22222" FontSize="11" Margin="0,0,0,10"
                           Visibility="Collapsed" HorizontalAlignment="Center" FontFamily="Tahoma"
                           TextWrapping="Wrap" />

                <!-- Activate Button -->
                <Button x:Name="ActivateButton" Content="Activate License" Click="ActivateButton_Click"
                        Background="#0054E3" Foreground="White" FontSize="12" FontWeight="Normal"
                        Padding="0,10" Cursor="Hand" FontFamily="Tahoma" BorderThickness="1"
                        BorderBrush="#0047AB" HorizontalContentAlignment="Center" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
