<Window x:Class="ClinicManager.Views.Dialogs.LicenseDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="License Activation" Height="560" Width="520"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#F1F5F9" WindowStyle="None" AllowsTransparency="True">

    <Border Background="White" CornerRadius="20" BorderBrush="#E2E8F0" BorderThickness="1"
            Margin="10">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="0" BlurRadius="20" Opacity="0.15" Color="#000000" />
        </Border.Effect>

        <Grid Margin="40,32">
            <!-- Close button -->
            <Button Content="✕" Click="ExitButton_Click" HorizontalAlignment="Right" VerticalAlignment="Top"
                    Background="Transparent" Foreground="#94A3B8" FontSize="16" BorderThickness="0" 
                    Cursor="Hand" Padding="4" Margin="-10,-10,0,0" />

            <StackPanel VerticalAlignment="Center" Margin="0,16,0,0">
                <!-- Logo -->
                <Border Width="56" Height="56" CornerRadius="14" Background="#4F46E5" 
                        HorizontalAlignment="Center" Margin="0,0,0,16">
                    <TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets" FontSize="24"
                               Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock Text="Clinic Manager" FontSize="24" FontWeight="Bold" 
                           Foreground="#0F172A" HorizontalAlignment="Center" FontFamily="Segoe UI" />
                <TextBlock Text="Activate your license to continue" FontSize="13" Foreground="#64748B"
                           HorizontalAlignment="Center" Margin="0,4,0,28" FontFamily="Segoe UI" />

                <!-- Machine ID -->
                <TextBlock Text="MACHINE ID" FontSize="11" Foreground="#94A3B8" 
                           FontWeight="Bold" Margin="0,0,0,6" FontFamily="Segoe UI" />
                <DockPanel Margin="0,0,0,6">
                    <Button x:Name="CopyButton" DockPanel.Dock="Right" Content="Copy" 
                            Click="CopyMachineId_Click" Margin="8,0,0,0"
                            Background="#4F46E5" Foreground="White" FontSize="12" FontWeight="SemiBold"
                            Padding="16,0" Cursor="Hand" FontFamily="Segoe UI" BorderThickness="0" Height="42">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="10" 
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#4338CA" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Border Background="#F8FAFC" CornerRadius="10" Padding="14,10" BorderBrush="#E2E8F0" BorderThickness="1.5">
                        <TextBox x:Name="MachineIdText" IsReadOnly="True" Background="Transparent" 
                                 BorderThickness="0" FontFamily="Cascadia Code, Consolas" FontSize="12"
                                 Foreground="#0F172A" VerticalAlignment="Center" />
                    </Border>
                </DockPanel>
                <TextBlock Text="Send this ID to get your license key" FontSize="11" 
                           Foreground="#94A3B8" Margin="0,0,0,20" FontFamily="Segoe UI" />

                <!-- License Key -->
                <TextBlock Text="LICENSE KEY" FontSize="11" Foreground="#94A3B8" 
                           FontWeight="Bold" Margin="0,0,0,6" FontFamily="Segoe UI" />
                <Border Background="#F8FAFC" CornerRadius="10" BorderBrush="#E2E8F0" BorderThickness="1.5" Margin="0,0,0,16">
                    <TextBox x:Name="LicenseKeyInput" Padding="14,12" BorderThickness="0" FontSize="15"
                             FontFamily="Cascadia Code, Consolas" Foreground="#0F172A" Background="Transparent"
                             CharacterCasing="Upper" />
                </Border>

                <!-- Name -->
                <TextBlock Text="LICENSED TO" FontSize="11" Foreground="#94A3B8" 
                           FontWeight="Bold" Margin="0,0,0,6" FontFamily="Segoe UI" />
                <Border Background="#F8FAFC" CornerRadius="10" BorderBrush="#E2E8F0" BorderThickness="1.5" Margin="0,0,0,24">
                    <TextBox x:Name="LicensedToInput" Padding="14,12" BorderThickness="0" FontSize="13"
                             FontFamily="Segoe UI" Foreground="#0F172A" Background="Transparent" />
                </Border>

                <!-- Error -->
                <TextBlock x:Name="ErrorText" Foreground="#DC2626" FontSize="12" Margin="0,0,0,12"
                           Visibility="Collapsed" HorizontalAlignment="Center" FontFamily="Segoe UI"
                           TextWrapping="Wrap" />

                <!-- Activate Button -->
                <Button x:Name="ActivateButton" Content="Activate License" Click="ActivateButton_Click"
                        Background="#4F46E5" Foreground="White" FontSize="14" FontWeight="SemiBold"
                        Padding="0,14" Cursor="Hand" FontFamily="Segoe UI" BorderThickness="0"
                        HorizontalContentAlignment="Center">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="12" 
                                    Padding="{TemplateBinding Padding}">
                                <Border.Effect>
                                    <DropShadowEffect ShadowDepth="1" BlurRadius="8" Opacity="0.2" Color="#4F46E5" />
                                </Border.Effect>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#4338CA" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
