<Window x:Class="ClinicManager.Views.Dialogs.ChangePasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Change Password Required" Height="340" Width="380"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="{DynamicResource BackgroundBrush}"
        WindowStyle="SingleBorderWindow">

    <Border Style="{DynamicResource CardStyle}" Margin="24" Padding="24">
        <StackPanel>
            <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" FontSize="36"
                       Foreground="{DynamicResource PrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,12" />
            <TextBlock Text="Change Password Required" FontSize="18" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,4" />
            <TextBlock Text="You must set a new password before continuing." FontSize="12"
                       Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,20"
                       TextWrapping="Wrap" TextAlignment="Center" />

            <TextBlock Text="New Password" Style="{DynamicResource FormLabelStyle}" />
            <PasswordBox x:Name="NewPasswordBox" Margin="0,4,0,12"
                         Style="{DynamicResource ModernPasswordBoxStyle}" />

            <TextBlock Text="Confirm Password" Style="{DynamicResource FormLabelStyle}" />
            <PasswordBox x:Name="ConfirmPasswordBox" Margin="0,4,0,12"
                         Style="{DynamicResource ModernPasswordBoxStyle}" />

            <TextBlock x:Name="ErrorText" Foreground="{DynamicResource DangerBrush}"
                       FontSize="12" TextWrapping="Wrap" Margin="0,0,0,12"
                       Visibility="Collapsed" />

            <Button x:Name="OkButton" Content="Change Password" Click="OkButton_Click"
                    Style="{DynamicResource PrimaryButtonStyle}" Padding="16,10" />
        </StackPanel>
    </Border>
</Window>
