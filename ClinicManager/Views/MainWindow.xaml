<Window x:Class="ClinicManager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ClinicManager.Localization"
        xmlns:pages="clr-namespace:ClinicManager.Views.Pages"
        xmlns:vm="clr-namespace:ClinicManager.ViewModels"
        Title="{local:Localize AppTitle}" 
        Height="700" Width="1100" MinHeight="500" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}"
        Icon="pack://application:,,,/ClinicManager;component/Resources/Icons/app.ico">

    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{Binding CurrentViewModel.RefreshCommand}" />
    </Window.InputBindings>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="200" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Classic Sidebar -->
        <Border Grid.Column="0" Background="{DynamicResource SidebarBrush}" 
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
            <DockPanel>

                <!-- Header -->
                <Border DockPanel.Dock="Top" Padding="8,8">
                    <DockPanel>
                        <Button x:Name="ToggleSidebarBtn" DockPanel.Dock="Left"
                                Click="ToggleSidebar_Click" 
                                Style="{DynamicResource SidebarToggleStyle}"
                                Width="24" Height="24" ToolTip="Toggle Sidebar (Ctrl+B)">
                            <TextBlock x:Name="ToggleIcon" Text="&#xE700;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                       Foreground="{DynamicResource SidebarTextBrush}" 
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Button>
                        <StackPanel x:Name="BrandingPanel" Orientation="Horizontal" Margin="6,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="ClinicPro" FontSize="12" FontWeight="Bold" 
                                       Foreground="{DynamicResource SidebarTextBrush}" FontFamily="Tahoma" />
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Divider -->
                <Border DockPanel.Dock="Top" Height="1" Background="{DynamicResource BorderBrush}" Margin="4,0" />

                <!-- Footer -->
                <StackPanel x:Name="FooterPanel" DockPanel.Dock="Bottom" Margin="8,0,8,8">
                    <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,0,0,6" />
                    <TextBlock x:Name="FooterText" Text="v1.0" FontSize="9" 
                               Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center" />
                </StackPanel>

                <!-- Navigation -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,4,0,0">
                    <StackPanel>
                        <TextBlock x:Name="LabelOverview" Text="Overview" FontSize="9" FontWeight="Bold" 
                                   Foreground="{DynamicResource TextMutedBrush}" Margin="10,4,0,2" />

                        <RadioButton Style="{DynamicResource NavButtonStyle}" IsChecked="True"
                                     Command="{Binding NavigateCommand}" CommandParameter="Dashboard"
                                     GroupName="Nav" ToolTip="Dashboard">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="11" 
                                           VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock x:Name="NavDashboard" Text="{local:Localize Dashboard}" 
                                           VerticalAlignment="Center" FontSize="11" />
                            </StackPanel>
                        </RadioButton>

                        <TextBlock x:Name="LabelManagement" Text="Management" FontSize="9" FontWeight="Bold" 
                                   Foreground="{DynamicResource TextMutedBrush}" Margin="10,10,0,2" />

                        <RadioButton Style="{DynamicResource NavButtonStyle}"
                                     Command="{Binding NavigateCommand}" CommandParameter="Patients"
                                     GroupName="Nav" ToolTip="Patient Management">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="11" 
                                           VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock x:Name="NavPatients" Text="Patient Management" 
                                           VerticalAlignment="Center" FontSize="11" />
                            </StackPanel>
                        </RadioButton>

                        <RadioButton Style="{DynamicResource NavButtonStyle}"
                                     Command="{Binding NavigateCommand}" CommandParameter="Appointments"
                                     GroupName="Nav" ToolTip="Appointments">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" FontSize="11" 
                                           VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock x:Name="NavAppointments" Text="{local:Localize Appointments}" 
                                           VerticalAlignment="Center" FontSize="11" />
                            </StackPanel>
                        </RadioButton>

                        <RadioButton Style="{DynamicResource NavButtonStyle}"
                                     Command="{Binding NavigateCommand}" CommandParameter="Staff"
                                     GroupName="Nav" ToolTip="Staff Management">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets" FontSize="11" 
                                           VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock x:Name="NavStaff" Text="Staff Management" 
                                           VerticalAlignment="Center" FontSize="11" />
                            </StackPanel>
                        </RadioButton>

                        <RadioButton Style="{DynamicResource NavButtonStyle}"
                                     Command="{Binding NavigateCommand}" CommandParameter="MedicalRecords"
                                     GroupName="Nav" ToolTip="Medical Records">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE82D;" FontFamily="Segoe MDL2 Assets" FontSize="11" 
                                           VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock x:Name="NavMedicalRecords" Text="{local:Localize MedicalRecords}" 
                                           VerticalAlignment="Center" FontSize="11" />
                            </StackPanel>
                        </RadioButton>

                        <TextBlock x:Name="LabelFinance" Text="Finance" FontSize="9" FontWeight="Bold" 
                                   Foreground="{DynamicResource TextMutedBrush}" Margin="10,10,0,2" />

                        <RadioButton Style="{DynamicResource NavButtonStyle}"
                                     Command="{Binding NavigateCommand}" CommandParameter="Billing"
                                     GroupName="Nav" ToolTip="Billing &amp; Payments">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8C7;" FontFamily="Segoe MDL2 Assets" FontSize="11" 
                                           VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock x:Name="NavBilling" Text="Billing &amp; Payments" 
                                           VerticalAlignment="Center" FontSize="11" />
                            </StackPanel>
                        </RadioButton>

                        <RadioButton Style="{DynamicResource NavButtonStyle}"
                                     Command="{Binding NavigateCommand}" CommandParameter="Inventory"
                                     GroupName="Nav" ToolTip="Inventory">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE773;" FontFamily="Segoe MDL2 Assets" FontSize="11" 
                                           VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock x:Name="NavInventory" Text="Inventory" 
                                           VerticalAlignment="Center" FontSize="11" />
                            </StackPanel>
                        </RadioButton>

                        <RadioButton Style="{DynamicResource NavButtonStyle}"
                                     Command="{Binding NavigateCommand}" CommandParameter="Reports"
                                     GroupName="Nav" ToolTip="Reports">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE9F9;" FontFamily="Segoe MDL2 Assets" FontSize="11" 
                                           VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock x:Name="NavReports" Text="Reports" 
                                           VerticalAlignment="Center" FontSize="11" />
                            </StackPanel>
                        </RadioButton>

                        <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="8,8,8,4" />

                        <TextBlock x:Name="LabelSystem" Text="System" FontSize="9" FontWeight="Bold" 
                                   Foreground="{DynamicResource TextMutedBrush}" Margin="10,4,0,2" />

                        <RadioButton Style="{DynamicResource NavButtonStyle}"
                                     Command="{Binding NavigateCommand}" CommandParameter="Settings"
                                     GroupName="Nav" ToolTip="Settings">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="11" 
                                           VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock x:Name="NavSettings" Text="{local:Localize Settings}" 
                                           VerticalAlignment="Center" FontSize="11" />
                            </StackPanel>
                        </RadioButton>

                    </StackPanel>
                </ScrollViewer>

            </DockPanel>
        </Border>

        <!-- Main Content Area -->
        <DockPanel Grid.Column="1" Background="{DynamicResource BackgroundBrush}">
            <!-- Top Bar: Language + Theme -->
            <Border DockPanel.Dock="Top" Height="44" Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                    Padding="16,0,20,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="{local:Localize Language}" VerticalAlignment="Center" Margin="0,0,6,0"
                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" />
                    <ComboBox x:Name="LangCombo" Width="120" SelectedIndex="{Binding SettingsVM.SelectedLanguageIndex}"
                              SelectionChanged="LangCombo_SelectionChanged" Padding="8,4" FontSize="12">
                        <ComboBoxItem Content="English" />
                        <ComboBoxItem Content="Français" />
                    </ComboBox>
                    <TextBlock Text="{local:Localize Theme}" VerticalAlignment="Center" Margin="16,0,6,0"
                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" />
                    <ComboBox x:Name="ThemeCombo" Width="100" SelectedIndex="{Binding SettingsVM.SelectedThemeIndex}"
                              SelectionChanged="ThemeCombo_SelectionChanged" Padding="8,4" FontSize="12">
                        <ComboBoxItem Content="{local:Localize LightMode}" />
                        <ComboBoxItem Content="{local:Localize DarkMode}" />
                    </ComboBox>
                </StackPanel>
            </Border>

            <ContentControl Content="{Binding CurrentViewModel}">
                <ContentControl.Resources>
                    <DataTemplate DataType="{x:Type vm:DashboardViewModel}"><pages:DashboardPage /></DataTemplate>
                    <DataTemplate DataType="{x:Type vm:PatientsViewModel}"><pages:PatientsPage /></DataTemplate>
                    <DataTemplate DataType="{x:Type vm:AppointmentsViewModel}"><pages:AppointmentsPage /></DataTemplate>
                    <DataTemplate DataType="{x:Type vm:StaffViewModel}"><pages:StaffPage /></DataTemplate>
                    <DataTemplate DataType="{x:Type vm:BillingViewModel}"><pages:BillingPage /></DataTemplate>
                    <DataTemplate DataType="{x:Type vm:InventoryViewModel}"><pages:InventoryPage /></DataTemplate>
                    <DataTemplate DataType="{x:Type vm:MedicalRecordsViewModel}"><pages:MedicalRecordsPage /></DataTemplate>
                    <DataTemplate DataType="{x:Type vm:ReportsViewModel}"><pages:ReportsPage /></DataTemplate>
                    <DataTemplate DataType="{x:Type vm:SettingsViewModel}"><pages:SettingsPage /></DataTemplate>
                </ContentControl.Resources>
            </ContentControl>
        </DockPanel>
    </Grid>
</Window>
