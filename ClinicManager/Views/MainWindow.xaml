<Window x:Class="ClinicManager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ClinicManager.Localization"
        xmlns:pages="clr-namespace:ClinicManager.Views.Pages"
        xmlns:vm="clr-namespace:ClinicManager.ViewModels"
        Title="{local:Localize AppTitle}" 
        Height="850" Width="1360" MinHeight="650" MinWidth="1050"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}">

    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{Binding CurrentViewModel.RefreshCommand}" />
    </Window.InputBindings>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ═══════════ SIDEBAR ═══════════ -->
        <Border Grid.Column="0" Background="{DynamicResource SidebarBrush}">
            <DockPanel>
                <!-- App Logo -->
                <Border DockPanel.Dock="Top" Padding="24,28,24,24">
                    <DockPanel>
                        <Border Width="42" Height="42" CornerRadius="12" 
                                Background="{DynamicResource PrimaryBrush}" Margin="0,0,14,0">
                            <TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Clinic Manager" FontSize="17" FontWeight="Bold" 
                                       Foreground="White" FontFamily="Segoe UI" />
                            <TextBlock Text="Management System" FontSize="10.5" 
                                       Foreground="{DynamicResource TextMutedBrush}" Margin="0,1,0,0" />
                        </StackPanel>
                    </DockPanel>
                </Border>

                <Border DockPanel.Dock="Top" Height="1" Background="{DynamicResource SidebarHoverBrush}" Margin="20,0" />

                <!-- Bottom info -->
                <StackPanel DockPanel.Dock="Bottom" Margin="20,0,20,20">
                    <Border Height="1" Background="{DynamicResource SidebarHoverBrush}" Margin="0,0,0,16" />
                    <TextBlock Text="v1.0.0  ·  ClinicSoft" FontSize="10.5" 
                               Foreground="{DynamicResource TextMutedBrush}" 
                               HorizontalAlignment="Center" />
                </StackPanel>

                <!-- Navigation Items -->
                <StackPanel Margin="0,20,0,0">
                    <TextBlock Text="MENU" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}"
                               Margin="28,0,0,10" />

                    <RadioButton Style="{DynamicResource NavButtonStyle}" 
                                 IsChecked="True"
                                 Command="{Binding NavigateCommand}" CommandParameter="Dashboard"
                                 GroupName="Nav">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="15" 
                                       VerticalAlignment="Center" Margin="0,0,14,0" />
                            <TextBlock Text="{local:Localize Dashboard}" VerticalAlignment="Center" FontWeight="SemiBold" />
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Style="{DynamicResource NavButtonStyle}"
                                 Command="{Binding NavigateCommand}" CommandParameter="Patients"
                                 GroupName="Nav">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="15" 
                                       VerticalAlignment="Center" Margin="0,0,14,0" />
                            <TextBlock Text="{local:Localize Patients}" VerticalAlignment="Center" FontWeight="SemiBold" />
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Style="{DynamicResource NavButtonStyle}"
                                 Command="{Binding NavigateCommand}" CommandParameter="Appointments"
                                 GroupName="Nav">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" FontSize="15" 
                                       VerticalAlignment="Center" Margin="0,0,14,0" />
                            <TextBlock Text="{local:Localize Appointments}" VerticalAlignment="Center" FontWeight="SemiBold" />
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Style="{DynamicResource NavButtonStyle}"
                                 Command="{Binding NavigateCommand}" CommandParameter="Billing"
                                 GroupName="Nav">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8C7;" FontFamily="Segoe MDL2 Assets" FontSize="15" 
                                       VerticalAlignment="Center" Margin="0,0,14,0" />
                            <TextBlock Text="{local:Localize Billing}" VerticalAlignment="Center" FontWeight="SemiBold" />
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Style="{DynamicResource NavButtonStyle}"
                                 Command="{Binding NavigateCommand}" CommandParameter="MedicalRecords"
                                 GroupName="Nav">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE82D;" FontFamily="Segoe MDL2 Assets" FontSize="15" 
                                       VerticalAlignment="Center" Margin="0,0,14,0" />
                            <TextBlock Text="{local:Localize MedicalRecords}" VerticalAlignment="Center" FontWeight="SemiBold" />
                        </StackPanel>
                    </RadioButton>

                    <Border Height="1" Background="{DynamicResource SidebarHoverBrush}" Margin="20,14" />

                    <TextBlock Text="SYSTEM" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}"
                               Margin="28,0,0,10" />

                    <RadioButton Style="{DynamicResource NavButtonStyle}"
                                 Command="{Binding NavigateCommand}" CommandParameter="Settings"
                                 GroupName="Nav">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="15" 
                                       VerticalAlignment="Center" Margin="0,0,14,0" />
                            <TextBlock Text="{local:Localize Settings}" VerticalAlignment="Center" FontWeight="SemiBold" />
                        </StackPanel>
                    </RadioButton>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══════════ MAIN CONTENT ═══════════ -->
        <ContentControl Grid.Column="1" Content="{Binding CurrentViewModel}">
            <ContentControl.Resources>
                <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
                    <pages:DashboardPage />
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:PatientsViewModel}">
                    <pages:PatientsPage />
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:AppointmentsViewModel}">
                    <pages:AppointmentsPage />
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:BillingViewModel}">
                    <pages:BillingPage />
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:MedicalRecordsViewModel}">
                    <pages:MedicalRecordsPage />
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
                    <pages:SettingsPage />
                </DataTemplate>
            </ContentControl.Resources>
        </ContentControl>
    </Grid>
</Window>
