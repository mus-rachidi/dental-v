<Window x:Class="ClinicManager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ClinicManager.Localization"
        xmlns:pages="clr-namespace:ClinicManager.Views.Pages"
        xmlns:vm="clr-namespace:ClinicManager.ViewModels"
        Title="{local:Localize AppTitle}" 
        Height="800" Width="1280" MinHeight="600" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}">

    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{Binding CurrentViewModel.RefreshCommand}" />
    </Window.InputBindings>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{DynamicResource SidebarBrush}">
            <DockPanel>
                <!-- App Branding -->
                <Border DockPanel.Dock="Top" Padding="24,24,24,20">
                    <StackPanel>
                        <TextBlock Text="Clinic Manager" FontSize="22" FontWeight="Bold" 
                                   Foreground="White" FontFamily="Segoe UI" />
                        <TextBlock Text="Management System" FontSize="11" 
                                   Foreground="{DynamicResource SidebarTextBrush}" Margin="0,2,0,0" />
                    </StackPanel>
                </Border>

                <Border DockPanel.Dock="Top" Height="1" Background="{DynamicResource SidebarHoverBrush}" Margin="16,0" />

                <!-- Version at bottom -->
                <TextBlock DockPanel.Dock="Bottom" Text="v1.0.0" FontSize="11" 
                           Foreground="{DynamicResource TextMutedBrush}" 
                           HorizontalAlignment="Center" Margin="0,0,0,16" />

                <!-- Navigation -->
                <StackPanel Margin="0,16,0,0">
                    <RadioButton Style="{DynamicResource NavButtonStyle}" 
                                 IsChecked="True"
                                 Command="{Binding NavigateCommand}" CommandParameter="Dashboard"
                                 GroupName="Nav">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="16" 
                                       VerticalAlignment="Center" Margin="0,0,12,0" />
                            <TextBlock Text="{local:Localize Dashboard}" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Style="{DynamicResource NavButtonStyle}"
                                 Command="{Binding NavigateCommand}" CommandParameter="Patients"
                                 GroupName="Nav">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="16" 
                                       VerticalAlignment="Center" Margin="0,0,12,0" />
                            <TextBlock Text="{local:Localize Patients}" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Style="{DynamicResource NavButtonStyle}"
                                 Command="{Binding NavigateCommand}" CommandParameter="Appointments"
                                 GroupName="Nav">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" FontSize="16" 
                                       VerticalAlignment="Center" Margin="0,0,12,0" />
                            <TextBlock Text="{local:Localize Appointments}" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Style="{DynamicResource NavButtonStyle}"
                                 Command="{Binding NavigateCommand}" CommandParameter="Billing"
                                 GroupName="Nav">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8C7;" FontFamily="Segoe MDL2 Assets" FontSize="16" 
                                       VerticalAlignment="Center" Margin="0,0,12,0" />
                            <TextBlock Text="{local:Localize Billing}" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Style="{DynamicResource NavButtonStyle}"
                                 Command="{Binding NavigateCommand}" CommandParameter="MedicalRecords"
                                 GroupName="Nav">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE82D;" FontFamily="Segoe MDL2 Assets" FontSize="16" 
                                       VerticalAlignment="Center" Margin="0,0,12,0" />
                            <TextBlock Text="{local:Localize MedicalRecords}" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>

                    <Border Height="1" Background="{DynamicResource SidebarHoverBrush}" Margin="16,12" />

                    <RadioButton Style="{DynamicResource NavButtonStyle}"
                                 Command="{Binding NavigateCommand}" CommandParameter="Settings"
                                 GroupName="Nav">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="16" 
                                       VerticalAlignment="Center" Margin="0,0,12,0" />
                            <TextBlock Text="{local:Localize Settings}" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main Content Area -->
        <ContentControl Grid.Column="1" Content="{Binding CurrentViewModel}">
            <ContentControl.Resources>
                <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
                    <pages:DashboardPage />
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:PatientsViewModel}">
                    <pages:PatientsPage />
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:AppointmentsViewModel}">
                    <pages:AppointmentsPage />
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:BillingViewModel}">
                    <pages:BillingPage />
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:MedicalRecordsViewModel}">
                    <pages:MedicalRecordsPage />
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
                    <pages:SettingsPage />
                </DataTemplate>
            </ContentControl.Resources>
        </ContentControl>
    </Grid>
</Window>
