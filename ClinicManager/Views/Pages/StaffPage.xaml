<UserControl x:Class="ClinicManager.Views.Pages.StaffPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <Border Width="64" Height="64" CornerRadius="32" Margin="0,0,0,16" HorizontalAlignment="Center">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#8B5CF6" Offset="0" />
                        <GradientStop Color="#A78BFA" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets" FontSize="28"
                           Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <TextBlock Text="Staff Management" FontSize="20" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,6" />
            <TextBlock Text="Manage doctors, nurses, and clinic staff members" FontSize="12"
                       Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,20" />
            <Border Style="{DynamicResource BadgeStyle}" Background="{DynamicResource WarningLightBrush}" 
                    HorizontalAlignment="Center" Padding="16,6">
                <TextBlock Text="Coming Soon" FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource WarningBrush}" />
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
