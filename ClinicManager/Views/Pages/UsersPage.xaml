<UserControl x:Class="ClinicManager.Views.Pages.UsersPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ClinicManager.Localization"
             xmlns:helpers="clr-namespace:ClinicManager.Helpers">

    <UserControl.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVis" />
        <helpers:EnumDescriptionConverter x:Key="EnumDesc" />
        <helpers:NullToVisibilityConverter x:Key="NullToVis" />
        <helpers:StringToVisibilityConverter x:Key="StringToVis" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="16,12,16,20" MaxWidth="800">

            <DockPanel Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets" FontSize="22"
                               Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" Margin="0,0,10,0" />
                    <TextBlock Text="User Management" Style="{DynamicResource PageTitleStyle}" />
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="&#xE710; Add User" Command="{Binding AddUserCommand}"
                            Style="{DynamicResource PrimaryButtonStyle}" Padding="12,8" Margin="0,0,8,0" />
                    <Button Content="&#xE72C; Refresh" Command="{Binding RefreshCommand}"
                            Style="{DynamicResource SecondaryButtonStyle}" Padding="12,8" />
                </StackPanel>
            </DockPanel>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="360" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{DynamicResource CardStyle}">
                    <DataGrid ItemsSource="{Binding Users}" SelectedItem="{Binding SelectedUser}"
                              Style="{DynamicResource ModernDataGridStyle}"
                              RowStyle="{DynamicResource ModernDataGridRowStyle}"
                              AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              SelectionMode="Single" GridLinesVisibility="None">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="*" />
                            <DataGridTextColumn Header="Role" Binding="{Binding Role, Converter={StaticResource EnumDesc}}" Width="100" />
                            <DataGridTextColumn Header="Status" Binding="{Binding Status, Converter={StaticResource EnumDesc}}" Width="80" />
                            <DataGridTextColumn Header="Last Login" Binding="{Binding LastLogin, StringFormat='{}{0:g}'}" Width="140" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <Border Grid.Column="2" Style="{DynamicResource CardStyle}"
                        Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="{Binding SelectedUser.Username, FallbackValue='New User'}" 
                                   Style="{DynamicResource SectionTitleStyle}" Margin="0,0,0,16" />

                        <TextBlock Text="Username" Style="{DynamicResource FormLabelStyle}" />
                        <TextBox Text="{Binding EditUsername, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{DynamicResource ModernTextBoxStyle}" Margin="0,4,0,12"
                                 IsEnabled="{Binding CanEditUsername}" />

                        <TextBlock Text="Password" Style="{DynamicResource FormLabelStyle}" />
                        <PasswordBox x:Name="EditPasswordBox" Margin="0,4,0,12"
                                     PasswordChanged="EditPasswordBox_PasswordChanged" />

                        <TextBlock Text="Role" Style="{DynamicResource FormLabelStyle}" />
                        <ComboBox ItemsSource="{Binding Roles}" SelectedItem="{Binding EditRole}"
                                  FontSize="13" Padding="10" Margin="0,4,0,12" />

                        <TextBlock Text="Status" Style="{DynamicResource FormLabelStyle}" />
                        <ComboBox ItemsSource="{Binding Statuses}" SelectedItem="{Binding EditStatus}"
                                  FontSize="13" Padding="10" Margin="0,4,0,12" />

                        <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource DangerBrush}"
                                   FontSize="12" TextWrapping="Wrap" Margin="0,0,0,12"
                                   Visibility="{Binding StatusMessage, Converter={StaticResource StringToVis}}" />

                        <StackPanel Orientation="Horizontal">
                            <Button Content="Save" Command="{Binding SaveUserCommand}"
                                    Style="{DynamicResource PrimaryButtonStyle}" Padding="16,8" Margin="0,0,8,0" />
                            <Button Content="Reset Password" Command="{Binding ResetPasswordCommand}"
                                    Style="{DynamicResource SecondaryButtonStyle}" Padding="12,8" Margin="0,0,8,0"
                                    Visibility="{Binding SelectedUser, Converter={StaticResource NullToVis}}" />
                            <Button Content="Cancel" Command="{Binding CancelEditCommand}"
                                    Style="{DynamicResource SecondaryButtonStyle}" Padding="12,8" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
