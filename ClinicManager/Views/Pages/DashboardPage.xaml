<UserControl x:Class="ClinicManager.Views.Pages.DashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ClinicManager.Localization"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             xmlns:helpers="clr-namespace:ClinicManager.Helpers">

    <UserControl.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVis" />
        <helpers:IntToVisibilityConverter x:Key="IntToVis" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="16,12,16,20">

            <!-- Header + Quick Actions -->
            <DockPanel Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="{local:Localize Dashboard}" Style="{DynamicResource PageTitleStyle}" />
                    <TextBlock Text="{local:Localize Welcome}" Foreground="{DynamicResource TextSecondaryBrush}" 
                               FontSize="12" Margin="0,2,0,0" />
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="&#xE710; Add Patient" Command="{Binding AddPatientCommand}"
                            Style="{DynamicResource PrimaryButtonStyle}" Padding="12,8" Margin="0,0,8,0" FontSize="12" />
                    <Button Content="&#xE787; Schedule" Command="{Binding ScheduleAppointmentCommand}"
                            Style="{DynamicResource SecondaryButtonStyle}" Padding="12,8" Margin="0,0,8,0" FontSize="12" />
                    <Button Content="&#xE72C; Refresh" Command="{Binding RefreshCommand}"
                            Style="{DynamicResource SecondaryButtonStyle}" Padding="12,8" FontSize="12" />
                </StackPanel>
            </DockPanel>

            <!-- Alerts -->
            <Border Visibility="{Binding HasAlerts, Converter={StaticResource BoolToVis}}"
                    Background="{DynamicResource WarningLightBrush}" Padding="12,10" Margin="0,0,0,12"
                    BorderBrush="{DynamicResource WarningBrush}" BorderThickness="1">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                               Foreground="{DynamicResource WarningBrush}" Margin="0,0,10,0" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding AlertMessage}" FontSize="12" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- Search + Filter -->
            <Border Style="{DynamicResource CardStyle}" Margin="0,0,0,12" Padding="12,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource ModernTextBoxStyle}" FontSize="12"
                             Tag="{local:Localize QuickSearch}" />
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{local:Localize From}" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                        <DatePicker SelectedDate="{Binding FilterFrom}" Width="110" FontSize="11" />
                        <TextBlock Text="{local:Localize To}" VerticalAlignment="Center" Margin="12,0,6,0" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                        <DatePicker SelectedDate="{Binding FilterTo}" Width="110" FontSize="11" />
                        <Button Content="{local:Localize Apply}" Command="{Binding FilterCommand}"
                                Style="{DynamicResource PrimaryButtonStyle}" Margin="12,0,0,0" Padding="12,6" FontSize="11" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- KPI Tiles (clickable) -->
            <UniformGrid Columns="4" Margin="0,0,0,12">
                <Border Style="{DynamicResource StatCardStyle}" Margin="0,0,6,6" Cursor="Hand"
                        MouseLeftButtonDown="KpiPatients_Click"
                        ToolTip="Click to view Patients">
                    <DockPanel>
                        <Border DockPanel.Dock="Left" Width="40" Height="40" Margin="0,0,12,0" CornerRadius="8"
                                Background="{DynamicResource PrimaryBrush}">
                            <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{local:Localize TotalPatients}" 
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" />
                            <TextBlock Text="{Binding TotalPatients}" FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,2,0,0" />
                        </StackPanel>
                    </DockPanel>
                </Border>

                <Border Style="{DynamicResource StatCardStyle}" Margin="6,0,6,6" Cursor="Hand"
                        MouseLeftButtonDown="KpiPatients_Click"
                        ToolTip="New patients this month">
                    <DockPanel>
                        <Border DockPanel.Dock="Left" Width="40" Height="40" Margin="0,0,12,0" CornerRadius="8"
                                Background="{DynamicResource SuccessBrush}">
                            <TextBlock Text="&#xE8FA;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="New This Month" 
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" />
                            <TextBlock Text="{Binding NewPatientsThisMonth}" FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource SuccessBrush}" Margin="0,2,0,0" />
                        </StackPanel>
                    </DockPanel>
                </Border>

                <Border Style="{DynamicResource StatCardStyle}" Margin="6,0,6,6" Cursor="Hand"
                        MouseLeftButtonDown="KpiAppointments_Click"
                        ToolTip="Click to view Appointments">
                    <DockPanel>
                        <Border DockPanel.Dock="Left" Width="40" Height="40" Margin="0,0,12,0" CornerRadius="8"
                                Background="{DynamicResource InfoBrush}">
                            <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{local:Localize TodayAppointments}" 
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" />
                            <TextBlock Text="{Binding TodayAppointments}" FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,2,0,0" />
                        </StackPanel>
                    </DockPanel>
                </Border>

                <Border Style="{DynamicResource StatCardStyle}" Margin="6,0,0,6" Cursor="Hand"
                        MouseLeftButtonDown="KpiAppointments_Click"
                        ToolTip="Upcoming appointments">
                    <DockPanel>
                        <Border DockPanel.Dock="Left" Width="40" Height="40" Margin="0,0,12,0" CornerRadius="8"
                                Background="#8B5CF6">
                            <TextBlock Text="&#xE823;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{local:Localize UpcomingAppointments}" 
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" />
                            <TextBlock Text="{Binding UpcomingAppointments}" FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,2,0,0" />
                        </StackPanel>
                    </DockPanel>
                </Border>

                <Border Style="{DynamicResource StatCardStyle}" Margin="0,6,6,6" Cursor="Hand"
                        MouseLeftButtonDown="KpiMedicalRecords_Click"
                        ToolTip="Completed treatments">
                    <DockPanel>
                        <Border DockPanel.Dock="Left" Width="40" Height="40" Margin="0,0,12,0" CornerRadius="8"
                                Background="{DynamicResource SuccessBrush}">
                            <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Completed Treatments" 
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" />
                            <TextBlock Text="{Binding CompletedTreatments}" FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource SuccessBrush}" Margin="0,2,0,0" />
                        </StackPanel>
                    </DockPanel>
                </Border>

                <Border Style="{DynamicResource StatCardStyle}" Margin="6,6,6,6" Cursor="Hand"
                        MouseLeftButtonDown="KpiBilling_Click"
                        ToolTip="Today's revenue">
                    <DockPanel>
                        <Border DockPanel.Dock="Left" Width="40" Height="40" Margin="0,0,12,0" CornerRadius="8"
                                Background="{DynamicResource SuccessBrush}">
                            <TextBlock Text="&#xE8C7;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{local:Localize TodayRevenue}" 
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" />
                            <TextBlock Text="{Binding TodayRevenue, StringFormat='{}{0:N0} MAD'}" FontSize="18" FontWeight="Bold"
                                       Foreground="{DynamicResource SuccessBrush}" Margin="0,2,0,0" />
                        </StackPanel>
                    </DockPanel>
                </Border>

                <Border Style="{DynamicResource StatCardStyle}" Margin="6,6,6,6" Cursor="Hand"
                        MouseLeftButtonDown="KpiBilling_Click"
                        ToolTip="This month's revenue">
                    <DockPanel>
                        <Border DockPanel.Dock="Left" Width="40" Height="40" Margin="0,0,12,0" CornerRadius="8"
                                Background="{DynamicResource WarningBrush}">
                            <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{local:Localize MonthRevenue}" 
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" />
                            <TextBlock Text="{Binding MonthRevenue, StringFormat='{}{0:N0} MAD'}" FontSize="18" FontWeight="Bold"
                                       Foreground="{DynamicResource WarningBrush}" Margin="0,2,0,0" />
                        </StackPanel>
                    </DockPanel>
                </Border>

                <Border Style="{DynamicResource StatCardStyle}" Margin="6,6,0,6" Cursor="Hand"
                        MouseLeftButtonDown="KpiBilling_Click"
                        ToolTip="Pending bills to collect">
                    <DockPanel>
                        <Border DockPanel.Dock="Left" Width="40" Height="40" Margin="0,0,12,0" CornerRadius="8"
                                Background="{DynamicResource DangerBrush}">
                            <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Pending Bills" 
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" />
                            <TextBlock Text="{Binding PendingBills, StringFormat='{}{0:N0} MAD'}" FontSize="18" FontWeight="Bold"
                                       Foreground="{DynamicResource DangerBrush}" Margin="0,2,0,0" />
                        </StackPanel>
                    </DockPanel>
                </Border>
            </UniformGrid>

            <!-- Charts Row -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="200" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="200" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Monthly Revenue (MAD)" Style="{DynamicResource SectionTitleStyle}" Margin="0,0,0,6" />
                <Border Grid.Row="1" Grid.Column="0" Style="{DynamicResource CardStyle}" Padding="12">
                    <lvc:CartesianChart Series="{Binding RevenueSeries}" XAxes="{Binding RevenueXAxes}"
                                       TooltipPosition="Top" />
                </Border>

                <TextBlock Grid.Row="0" Grid.Column="2" Text="Appointments by Doctor" Style="{DynamicResource SectionTitleStyle}" Margin="0,0,0,6" />
                <Border Grid.Row="1" Grid.Column="2" Style="{DynamicResource CardStyle}" Padding="12">
                    <lvc:PieChart Series="{Binding DoctorPieSeries}" 
                                  InitialRotation="-90" MaxAngle="360"
                                  TooltipPosition="Right" />
                </Border>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Tooth Conditions" Style="{DynamicResource SectionTitleStyle}" Margin="0,12,0,6" />
                <Border Grid.Row="3" Grid.Column="0" Style="{DynamicResource CardStyle}" Padding="12">
                    <lvc:PieChart Series="{Binding TreatmentPieSeries}" 
                                  InitialRotation="-90" MaxAngle="360"
                                  TooltipPosition="Right" />
                </Border>

                <TextBlock Grid.Row="2" Grid.Column="2" Text="Patient Demographics" Style="{DynamicResource SectionTitleStyle}" Margin="0,12,0,6" />
                <Border Grid.Row="3" Grid.Column="2" Style="{DynamicResource CardStyle}" Padding="12">
                    <lvc:PieChart Series="{Binding DemographicsPieSeries}" 
                                  InitialRotation="-90" MaxAngle="360"
                                  TooltipPosition="Right" />
                </Border>
            </Grid>

            <!-- Bottom: Today's Appointments + Recent Patients -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="320" />
                </Grid.ColumnDefinitions>

                <Border Style="{DynamicResource CardStyle}" Padding="16">
                    <DockPanel>
                        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                            <TextBlock Text="{local:Localize TodayAppointments}" Style="{DynamicResource SectionTitleStyle}" />
                            <Button Content="{local:Localize Appointments}" DockPanel.Dock="Right" 
                                    Command="{Binding ViewAllAppointmentsCommand}"
                                    Style="{DynamicResource SecondaryButtonStyle}" Padding="10,6" FontSize="11" />
                        </DockPanel>
                        <ItemsControl ItemsSource="{Binding TodayAppointmentsList}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,6" Padding="10,8" Cursor="Hand"
                                            Background="{DynamicResource RowAlternateBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                            MouseLeftButtonDown="Appointment_Click">
                                        <DockPanel>
                                            <Border Width="4" Margin="0,0,10,0" Background="{DynamicResource PrimaryBrush}" />
                                            <StackPanel>
                                                <TextBlock Text="{Binding Patient.FullName}" FontWeight="SemiBold" 
                                                           Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" />
                                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                    <TextBlock Text="{Binding Time, StringFormat='{}{0:hh\\:mm}'}" 
                                                               Foreground="{DynamicResource PrimaryBrush}" FontSize="11" />
                                                    <TextBlock Text=" • " Foreground="{DynamicResource TextMutedBrush}" />
                                                    <TextBlock Text="{Binding DoctorName}" 
                                                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" />
                                                </StackPanel>
                                            </StackPanel>
                                            <Border DockPanel.Dock="Right" Padding="8,4" CornerRadius="4"
                                                    Background="{DynamicResource PrimaryLightBrush}" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Status}" FontSize="10" 
                                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                                            </Border>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="{local:Localize NoAppointmentsToday}" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"
                                   Margin="0,20,0,0"
                                   Visibility="{Binding TodayAppointments, Converter={StaticResource IntToVis}, ConverterParameter=ZeroToVisible}" />
                    </DockPanel>
                </Border>

                <Border Grid.Column="2" Style="{DynamicResource CardStyle}" Padding="16">
                    <DockPanel>
                        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                            <TextBlock Text="{local:Localize RecentPatients}" Style="{DynamicResource SectionTitleStyle}" />
                            <Button Content="{local:Localize Patients}" DockPanel.Dock="Right"
                                    Command="{Binding ViewAllPatientsCommand}"
                                    Style="{DynamicResource SecondaryButtonStyle}" Padding="10,6" FontSize="11" />
                        </DockPanel>
                        <ItemsControl ItemsSource="{Binding RecentPatients}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,6" Padding="10,8" Cursor="Hand"
                                            Background="{DynamicResource RowAlternateBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                            MouseLeftButtonDown="Patient_Click">
                                        <DockPanel>
                                            <Border Width="36" Height="36" Margin="0,0,10,0" CornerRadius="4"
                                                    Background="{DynamicResource PrimaryBrush}">
                                                <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                           Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding FullName}" FontWeight="SemiBold" FontSize="12"
                                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                                                <TextBlock Text="{Binding Phone}" FontSize="11" Margin="0,2,0,0"
                                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </DockPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
