<UserControl x:Class="ClinicManager.Views.Pages.DashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ClinicManager.Localization">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="12,8,12,12">

            <DockPanel Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="{local:Localize Dashboard}" Style="{DynamicResource PageTitleStyle}" />
                    <TextBlock Text="{local:Localize Welcome}" Foreground="{DynamicResource TextSecondaryBrush}" 
                               FontSize="11" Margin="0,2,0,0" />
                </StackPanel>
                <Button DockPanel.Dock="Right" Content="Refresh" Command="{Binding RefreshCommand}" 
                        Style="{DynamicResource SecondaryButtonStyle}" Padding="10,4" FontSize="11" />
            </DockPanel>

            <Border Style="{DynamicResource CardStyle}" Margin="0,0,0,8" Padding="4">
                <TextBox Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                         Style="{DynamicResource ModernTextBoxStyle}" FontSize="11" />
            </Border>

            <UniformGrid Columns="4" Margin="0,0,0,8">
                <Border Style="{DynamicResource StatCardStyle}" Margin="0,0,4,0">
                    <DockPanel>
                        <Border DockPanel.Dock="Left" Width="28" Height="28" Margin="0,0,8,0" 
                                Background="{DynamicResource PrimaryBrush}">
                            <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{local:Localize TotalPatients}" 
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="10" />
                            <TextBlock Text="{Binding TotalPatients}" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,1,0,0" />
                        </StackPanel>
                    </DockPanel>
                </Border>
                <Border Style="{DynamicResource StatCardStyle}" Margin="4,0">
                    <DockPanel>
                        <Border DockPanel.Dock="Left" Width="28" Height="28" Margin="0,0,8,0" 
                                Background="{DynamicResource InfoBrush}">
                            <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{local:Localize TodayAppointments}" 
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="10" />
                            <TextBlock Text="{Binding TodayAppointments}" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,1,0,0" />
                        </StackPanel>
                    </DockPanel>
                </Border>
                <Border Style="{DynamicResource StatCardStyle}" Margin="4,0">
                    <DockPanel>
                        <Border DockPanel.Dock="Left" Width="28" Height="28" Margin="0,0,8,0" 
                                Background="{DynamicResource SuccessBrush}">
                            <TextBlock Text="&#xE8C7;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{local:Localize TodayRevenue}" 
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="10" />
                            <TextBlock Text="{Binding TodayRevenue, StringFormat='{}{0:N2} MAD'}" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource SuccessBrush}" Margin="0,1,0,0" />
                        </StackPanel>
                    </DockPanel>
                </Border>
                <Border Style="{DynamicResource StatCardStyle}" Margin="4,0,0,0">
                    <DockPanel>
                        <Border DockPanel.Dock="Left" Width="28" Height="28" Margin="0,0,8,0" 
                                Background="{DynamicResource WarningBrush}">
                            <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{local:Localize MonthRevenue}" 
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="10" />
                            <TextBlock Text="{Binding MonthRevenue, StringFormat='{}{0:N2} MAD'}" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource WarningBrush}" Margin="0,1,0,0" />
                        </StackPanel>
                    </DockPanel>
                </Border>
            </UniformGrid>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="280" />
                </Grid.ColumnDefinitions>

                <Border Style="{DynamicResource CardStyle}" Grid.Column="0">
                    <DockPanel>
                        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                            <TextBlock Text="{local:Localize TodayAppointments}" Style="{DynamicResource SectionTitleStyle}" />
                            <Button Content="{local:Localize Appointments}" DockPanel.Dock="Right" 
                                    Command="{Binding ViewAllAppointmentsCommand}"
                                    Style="{DynamicResource SecondaryButtonStyle}" Padding="8,4" FontSize="10" />
                        </DockPanel>
                        <ItemsControl ItemsSource="{Binding TodayAppointmentsList}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,4" Padding="8,6"
                                            Background="{DynamicResource RowAlternateBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                        <DockPanel>
                                            <Border Width="3" Margin="0,0,8,0" Background="{DynamicResource PrimaryBrush}" />
                                            <StackPanel>
                                                <TextBlock Text="{Binding Patient.FullName}" FontWeight="SemiBold" 
                                                           Foreground="{DynamicResource TextPrimaryBrush}" FontSize="11" />
                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                    <TextBlock Text="{Binding Time, StringFormat='{}{0:hh\\:mm}'}" 
                                                               Foreground="{DynamicResource PrimaryBrush}" FontSize="10" />
                                                    <TextBlock Text=" - " Foreground="{DynamicResource TextMutedBrush}" />
                                                    <TextBlock Text="{Binding DoctorName}" 
                                                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="10" />
                                                </StackPanel>
                                            </StackPanel>
                                            <Border DockPanel.Dock="Right" Padding="6,2" 
                                                    Background="{DynamicResource PrimaryLightBrush}" VerticalAlignment="Center"
                                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                                <TextBlock Text="{Binding Status}" FontSize="9" 
                                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                                            </Border>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </DockPanel>
                </Border>

                <Border Style="{DynamicResource CardStyle}" Grid.Column="2">
                    <DockPanel>
                        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                            <TextBlock Text="{local:Localize RecentPatients}" Style="{DynamicResource SectionTitleStyle}" />
                            <Button Content="{local:Localize Patients}" DockPanel.Dock="Right"
                                    Command="{Binding ViewAllPatientsCommand}"
                                    Style="{DynamicResource SecondaryButtonStyle}" Padding="8,4" FontSize="10" />
                        </DockPanel>
                        <ItemsControl ItemsSource="{Binding RecentPatients}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,4" Padding="8,6"
                                            Background="{DynamicResource RowAlternateBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                        <DockPanel>
                                            <Border Width="28" Height="28" Margin="0,0,8,0" 
                                                    Background="{DynamicResource PrimaryBrush}">
                                                <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                           Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding FullName}" FontWeight="SemiBold" FontSize="11"
                                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                                                <TextBlock Text="{Binding Phone}" FontSize="10" Margin="0,1,0,0"
                                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </DockPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
