<UserControl x:Class="ClinicManager.Views.Pages.DashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ClinicManager.Localization">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32,24">
        <StackPanel>
            <!-- Page Header -->
            <DockPanel Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="{local:Localize Dashboard}" Style="{DynamicResource PageTitleStyle}" />
                    <TextBlock Text="{local:Localize Welcome}" Style="{DynamicResource FormLabelStyle}" Margin="0,4,0,0" />
                </StackPanel>
                <Button DockPanel.Dock="Right" Content="{local:Localize Refresh}" 
                        Command="{Binding RefreshCommand}" 
                        Style="{DynamicResource SecondaryButtonStyle}"
                        HorizontalAlignment="Right" VerticalAlignment="Center" />
            </DockPanel>

            <!-- Quick Search -->
            <Border Style="{DynamicResource CardStyle}" Margin="0,0,0,24">
                <TextBox Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                         Style="{DynamicResource ModernTextBoxStyle}"
                         Tag="{local:Localize QuickSearch}" />
            </Border>

            <!-- Stats Cards Row -->
            <UniformGrid Columns="4" Margin="0,0,0,24">
                <!-- Total Patients -->
                <Border Style="{DynamicResource StatCardStyle}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="{local:Localize TotalPatients}" 
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding TotalPatients}" FontSize="32" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryBrush}" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>

                <!-- Today Appointments -->
                <Border Style="{DynamicResource StatCardStyle}" Margin="6,0">
                    <StackPanel>
                        <TextBlock Text="{local:Localize TodayAppointments}" 
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding TodayAppointments}" FontSize="32" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentBrush}" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>

                <!-- Today Revenue -->
                <Border Style="{DynamicResource StatCardStyle}" Margin="6,0">
                    <StackPanel>
                        <TextBlock Text="{local:Localize TodayRevenue}" 
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding TodayRevenue, StringFormat='{}{0:C}'}" FontSize="32" FontWeight="Bold"
                                   Foreground="{DynamicResource SuccessBrush}" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>

                <!-- Month Revenue -->
                <Border Style="{DynamicResource StatCardStyle}" Margin="12,0,0,0">
                    <StackPanel>
                        <TextBlock Text="{local:Localize MonthRevenue}" 
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding MonthRevenue, StringFormat='{}{0:C}'}" FontSize="32" FontWeight="Bold"
                                   Foreground="{DynamicResource WarningBrush}" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Content Row -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="360" />
                </Grid.ColumnDefinitions>

                <!-- Today's Appointments -->
                <Border Style="{DynamicResource CardStyle}" Grid.Column="0" Margin="0,0,12,0">
                    <DockPanel>
                        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,16">
                            <TextBlock Text="{local:Localize TodayAppointments}" Style="{DynamicResource SectionTitleStyle}" />
                            <Button Content="{local:Localize Appointments}" DockPanel.Dock="Right" 
                                    Command="{Binding ViewAllAppointmentsCommand}"
                                    Style="{DynamicResource SecondaryButtonStyle}" Padding="12,6"
                                    HorizontalAlignment="Right" FontSize="12" />
                        </DockPanel>

                        <ItemsControl ItemsSource="{Binding TodayAppointmentsList}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,10">
                                        <DockPanel>
                                            <Border Width="4" CornerRadius="2" Margin="0,0,12,0">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
                                                    </Style>
                                                </Border.Style>
                                            </Border>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Patient.FullName}" FontWeight="SemiBold" 
                                                           Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14" />
                                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                    <TextBlock Text="{Binding Time, StringFormat='{}{0:hh\\:mm}'}" 
                                                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" />
                                                    <TextBlock Text=" - " Foreground="{DynamicResource TextMutedBrush}" />
                                                    <TextBlock Text="{Binding DoctorName}" 
                                                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" />
                                                </StackPanel>
                                            </StackPanel>
                                            <Border DockPanel.Dock="Right" HorizontalAlignment="Right" CornerRadius="12" 
                                                    Padding="10,4" Background="{DynamicResource PrimaryLightBrush}">
                                                <TextBlock Text="{Binding Status}" FontSize="11" 
                                                           Foreground="{DynamicResource PrimaryBrush}" FontWeight="SemiBold" />
                                            </Border>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </DockPanel>
                </Border>

                <!-- Recent Patients -->
                <Border Style="{DynamicResource CardStyle}" Grid.Column="1" Margin="12,0,0,0">
                    <DockPanel>
                        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,16">
                            <TextBlock Text="{local:Localize RecentPatients}" Style="{DynamicResource SectionTitleStyle}" />
                            <Button Content="{local:Localize Patients}" DockPanel.Dock="Right"
                                    Command="{Binding ViewAllPatientsCommand}"
                                    Style="{DynamicResource SecondaryButtonStyle}" Padding="12,6"
                                    HorizontalAlignment="Right" FontSize="12" />
                        </DockPanel>

                        <ItemsControl ItemsSource="{Binding RecentPatients}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,10">
                                        <DockPanel>
                                            <Ellipse Width="40" Height="40" Margin="0,0,12,0">
                                                <Ellipse.Fill>
                                                    <SolidColorBrush Color="{DynamicResource PrimaryLightColor}" />
                                                </Ellipse.Fill>
                                            </Ellipse>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding FullName}" FontWeight="SemiBold" FontSize="14"
                                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                                                <TextBlock Text="{Binding Phone}" FontSize="12"
                                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </DockPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
