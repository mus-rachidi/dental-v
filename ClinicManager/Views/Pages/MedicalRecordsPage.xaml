<UserControl x:Class="ClinicManager.Views.Pages.MedicalRecordsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ClinicManager.Localization"
             xmlns:helpers="clr-namespace:ClinicManager.Helpers">

    <UserControl.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid>
        <!-- Main List -->
        <DockPanel Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
            <DockPanel DockPanel.Dock="Top" Margin="16,12,16,8">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE82D;" FontFamily="Segoe MDL2 Assets" FontSize="22"
                               Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" Margin="0,0,10,0" />
                    <TextBlock Text="{local:Localize MedicalRecords}" Style="{DynamicResource PageTitleStyle}" VerticalAlignment="Center" />
                </StackPanel>
                <Button DockPanel.Dock="Right" Content="{local:Localize AddRecord}" 
                        Command="{Binding AddCommand}"
                        Style="{DynamicResource PrimaryButtonStyle}" Padding="16,8" HorizontalAlignment="Right" />
            </DockPanel>

            <Border DockPanel.Dock="Top" Margin="16,0,16,8">
                <TextBox Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                         Style="{DynamicResource ModernTextBoxStyle}"
                         Tag="{local:Localize Search}" />
            </Border>

            <Border Margin="16,0,16,12" Style="{DynamicResource CardStyle}" Padding="0">
                <DataGrid ItemsSource="{Binding Records}" 
                          SelectedItem="{Binding SelectedRecord}"
                          Style="{DynamicResource ModernDataGridStyle}"
                          ColumnHeaderStyle="{DynamicResource ModernDataGridColumnHeaderStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50" />
                        <DataGridTextColumn Header="{local:Localize PatientName}" Binding="{Binding Patient.FullName}" Width="*" />
                        <DataGridTextColumn Header="{local:Localize Date}" 
                                            Binding="{Binding Date, StringFormat='{}{0:yyyy-MM-dd}'}" Width="110" />
                        <DataGridTextColumn Header="{local:Localize Doctor}" Binding="{Binding DoctorName}" Width="150" />
                        <DataGridTextColumn Header="{local:Localize Diagnosis}" Binding="{Binding Diagnosis}" Width="200" />
                    </DataGrid.Columns>
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="{local:Localize Edit}" Command="{Binding EditCommand}" />
                            <MenuItem Header="{local:Localize Delete}" Command="{Binding DeleteCommand}" />
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                </DataGrid>
            </Border>
        </DockPanel>

        <!-- Edit Form -->
        <ScrollViewer Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}"
                      VerticalScrollBarVisibility="Auto" Padding="32,24">
            <Border Style="{DynamicResource CardStyle}" MaxWidth="700" HorizontalAlignment="Center">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                        <Border Width="32" Height="32" CornerRadius="8" Margin="0,0,12,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#2563EB" Offset="0" />
                                    <GradientStop Color="#3B82F6" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="&#xE82D;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="{local:Localize AddRecord}" 
                                   Style="{DynamicResource PageTitleStyle}" VerticalAlignment="Center" />
                    </StackPanel>

                    <TextBlock Text="{local:Localize SelectPatient}" Style="{DynamicResource FormLabelStyle}" />
                    <ComboBox ItemsSource="{Binding AvailablePatients}" 
                              SelectedValue="{Binding EditPatientId}" SelectedValuePath="Id"
                              DisplayMemberPath="FullName" FontSize="13" Padding="10" Margin="0,0,0,16" />

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{local:Localize Date}" Style="{DynamicResource FormLabelStyle}" />
                            <DatePicker SelectedDate="{Binding EditDate}" FontSize="13" Padding="8" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{local:Localize Doctor}" Style="{DynamicResource FormLabelStyle}" />
                            <TextBox Text="{Binding EditDoctor, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource ModernTextBoxStyle}" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="{local:Localize Vitals}" Style="{DynamicResource FormLabelStyle}" />
                    <TextBox Text="{Binding EditVitals, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource ModernTextBoxStyle}" Margin="0,0,0,16" />

                    <TextBlock Text="{local:Localize Diagnosis}" Style="{DynamicResource FormLabelStyle}" />
                    <TextBox Text="{Binding EditDiagnosis, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource ModernTextBoxStyle}" AcceptsReturn="True"
                             MinHeight="80" TextWrapping="Wrap" Margin="0,0,0,16" />

                    <TextBlock Text="{local:Localize Prescription}" Style="{DynamicResource FormLabelStyle}" />
                    <TextBox Text="{Binding EditPrescription, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource ModernTextBoxStyle}" AcceptsReturn="True"
                             MinHeight="80" TextWrapping="Wrap" Margin="0,0,0,16" />

                    <TextBlock Text="{local:Localize Notes}" Style="{DynamicResource FormLabelStyle}" />
                    <TextBox Text="{Binding EditNotes, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource ModernTextBoxStyle}" AcceptsReturn="True"
                             MinHeight="60" TextWrapping="Wrap" Margin="0,0,0,24" />

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="{local:Localize Cancel}" Command="{Binding CancelEditCommand}"
                                Style="{DynamicResource SecondaryButtonStyle}" Margin="0,0,8,0" />
                        <Button Content="{local:Localize Save}" Command="{Binding SaveCommand}"
                                Style="{DynamicResource PrimaryButtonStyle}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</UserControl>
