<UserControl x:Class="ClinicManager.Views.Pages.PatientsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ClinicManager.Localization"
             xmlns:helpers="clr-namespace:ClinicManager.Helpers"
             xmlns:models="clr-namespace:ClinicManager.Models"
             xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <UserControl.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVis" />
        <helpers:NullToVisibilityConverter x:Key="NullToVis" />
        <helpers:StringToBrushConverter x:Key="StringToBrush" />
    </UserControl.Resources>

    <Grid>
        <!-- ==================== MAIN VIEW (List + Detail) ==================== -->
        <Grid Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header Bar -->
            <DockPanel Grid.Row="0" Margin="20,16,20,10">
                <TextBlock Text="{local:Localize Patients}" Style="{DynamicResource PageTitleStyle}" VerticalAlignment="Center" />
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="{local:Localize ExportToPDF}" Command="{Binding ExportPdfCommand}"
                            Style="{DynamicResource SecondaryButtonStyle}" Margin="0,0,8,0" Padding="16,8" />
                    <Button Content="{local:Localize ExportToExcel}" Command="{Binding ExportExcelCommand}"
                            Style="{DynamicResource SecondaryButtonStyle}" Margin="0,0,8,0" Padding="16,8" />
                    <Button Content="{local:Localize AddPatient}" Command="{Binding AddCommand}"
                            Style="{DynamicResource PrimaryButtonStyle}" Padding="16,8" />
                </StackPanel>
            </DockPanel>

            <!-- Search Bar -->
            <Border Grid.Row="1" Margin="20,0,20,10">
                <TextBox Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                         Style="{DynamicResource ModernTextBoxStyle}"
                         Tag="{local:Localize SearchPatients}" />
            </Border>

            <!-- Content: Patient Grid + Right Detail Panel -->
            <Grid Grid.Row="2" Margin="20,0,20,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="340" />
                </Grid.ColumnDefinitions>

                <!-- Patient Data Grid -->
                <Border Grid.Column="0" Style="{DynamicResource CardStyle}" Padding="0">
                    <DataGrid ItemsSource="{Binding Patients}" 
                              SelectedItem="{Binding SelectedPatient}"
                              Style="{DynamicResource ModernDataGridStyle}"
                              ColumnHeaderStyle="{DynamicResource ModernDataGridColumnHeaderStyle}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50" />
                            <DataGridTextColumn Header="{local:Localize FullName}" Binding="{Binding FullName}" Width="*" />
                            <DataGridTextColumn Header="{local:Localize Phone}" Binding="{Binding Phone}" Width="120" />
                            <DataGridTextColumn Header="{local:Localize DateOfBirth}" 
                                                Binding="{Binding DateOfBirth, StringFormat='{}{0:yyyy-MM-dd}'}" Width="100" />
                            <DataGridTextColumn Header="{local:Localize Gender}" Binding="{Binding Gender}" Width="70" />
                        </DataGrid.Columns>
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="{local:Localize Edit}" Command="{Binding EditCommand}" />
                                <MenuItem Header="{local:Localize Delete}" Command="{Binding DeleteCommand}" />
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                    </DataGrid>
                </Border>

                <!-- ==================== RIGHT PANEL: Patient Detail + Dental Chart ==================== -->
                <Border Grid.Column="2" Style="{DynamicResource CardStyle}" Padding="0">
                    <Grid>
                        <!-- Placeholder when no patient selected -->
                        <StackPanel Visibility="{Binding HasSelection, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"
                                    VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="48"
                                       HorizontalAlignment="Center" Margin="0,0,0,12"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Opacity="0.4" />
                            <TextBlock Text="Select a patient" FontSize="14"
                                       Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" />
                        </StackPanel>

                        <!-- Patient detail when selected -->
                        <DockPanel Visibility="{Binding HasSelection, Converter={StaticResource BoolToVis}}">

                            <!-- Tab Buttons at top -->
                            <Border DockPanel.Dock="Top" Background="{DynamicResource SurfaceBrush}" Padding="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Content="Patient Info" 
                                            Command="{Binding ShowInfoTabCommand}"
                                            Click="InfoTab_Click"
                                            Background="Transparent" BorderThickness="0"
                                            FontWeight="SemiBold" FontSize="13" Padding="8,10" Cursor="Hand"
                                            Foreground="{DynamicResource TextPrimaryBrush}" />
                                    <Button Grid.Column="1" Content="Dental Chart"
                                            Command="{Binding ShowChartTabCommand}"
                                            Click="ChartTab_Click"
                                            Background="Transparent" BorderThickness="0"
                                            FontWeight="SemiBold" FontSize="13" Padding="8,10" Cursor="Hand"
                                            Foreground="{DynamicResource TextPrimaryBrush}" />
                                </Grid>
                            </Border>

                            <!-- ===== INFO TAB ===== -->
                            <ScrollViewer x:Name="InfoPanel" VerticalScrollBarVisibility="Auto" Padding="20,16">
                                <StackPanel>
                                    <!-- Patient Photo -->
                                    <Border Width="64" Height="64" CornerRadius="32" 
                                            Background="{DynamicResource SurfaceBrush}" 
                                            HorizontalAlignment="Center" Margin="0,0,0,12"
                                            BorderBrush="{DynamicResource PrimaryBrush}" BorderThickness="3">
                                        <Border CornerRadius="32">
                                            <Border.Background>
                                                <ImageBrush ImageSource="{Binding SelectedPatient.PhotoPath, TargetNullValue={x:Null}}" 
                                                            Stretch="UniformToFill" />
                                            </Border.Background>
                                            <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="32"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                                        </Border>
                                    </Border>

                                    <TextBlock Text="{Binding SelectedPatient.FullName}" 
                                               FontWeight="Bold" FontSize="17" HorizontalAlignment="Center" Margin="0,0,0,4"
                                               Foreground="{DynamicResource TextPrimaryBrush}" />
                                    <TextBlock Text="{Binding SelectedPatient.Phone}" 
                                               FontSize="13" HorizontalAlignment="Center" Margin="0,0,0,2"
                                               Foreground="{DynamicResource TextSecondaryBrush}" />
                                    <TextBlock Text="{Binding SelectedPatient.Email}" 
                                               FontSize="12" HorizontalAlignment="Center" Margin="0,0,0,16"
                                               Foreground="{DynamicResource TextSecondaryBrush}" />

                                    <!-- Quick Stats -->
                                    <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding HealthyCount}" FontSize="22" FontWeight="Bold"
                                                           HorizontalAlignment="Center" Foreground="#10B981" />
                                                <TextBlock Text="Healthy" FontSize="11" HorizontalAlignment="Center"
                                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding IssueCount}" FontSize="22" FontWeight="Bold"
                                                           HorizontalAlignment="Center" Foreground="#EF4444" />
                                                <TextBlock Text="Issues" FontSize="11" HorizontalAlignment="Center"
                                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- Info Fields -->
                                    <StackPanel Margin="0,4,0,0">
                                        <TextBlock Text="DATE OF BIRTH" FontSize="10" FontWeight="Bold" Margin="0,0,0,2"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                                        <TextBlock Text="{Binding SelectedPatient.DateOfBirth, StringFormat='{}{0:yyyy-MM-dd}'}" 
                                                   FontSize="13" Margin="0,0,0,10"
                                                   Foreground="{DynamicResource TextPrimaryBrush}" />

                                        <TextBlock Text="GENDER" FontSize="10" FontWeight="Bold" Margin="0,0,0,2"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                                        <TextBlock Text="{Binding SelectedPatient.Gender}" 
                                                   FontSize="13" Margin="0,0,0,10"
                                                   Foreground="{DynamicResource TextPrimaryBrush}" />

                                        <TextBlock Text="ADDRESS" FontSize="10" FontWeight="Bold" Margin="0,0,0,2"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                                        <TextBlock Text="{Binding SelectedPatient.Address, FallbackValue='-'}" 
                                                   FontSize="13" Margin="0,0,0,10" TextWrapping="Wrap"
                                                   Foreground="{DynamicResource TextPrimaryBrush}" />

                                        <TextBlock Text="NOTES" FontSize="10" FontWeight="Bold" Margin="0,0,0,2"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                                        <TextBlock Text="{Binding SelectedPatient.Notes, FallbackValue='-'}" 
                                                   FontSize="13" Margin="0,0,0,16" TextWrapping="Wrap"
                                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                                    </StackPanel>

                                    <!-- Action Buttons -->
                                    <Button Content="Edit Patient" Command="{Binding EditCommand}"
                                            Style="{DynamicResource PrimaryButtonStyle}" Margin="0,0,0,8" />
                                    <Button Content="Delete" Command="{Binding DeleteCommand}"
                                            Style="{DynamicResource SecondaryButtonStyle}" 
                                            Foreground="#EF4444" BorderBrush="#EF4444" />
                                </StackPanel>
                            </ScrollViewer>

                            <!-- ===== DENTAL CHART TAB ===== -->
                            <ScrollViewer x:Name="ChartPanel" VerticalScrollBarVisibility="Auto" 
                                          Padding="16,12" Visibility="Collapsed">
                                <StackPanel>
                                    <!-- Legend -->
                                    <TextBlock Text="TOOTH CONDITIONS" FontSize="10" FontWeight="Bold" Margin="0,0,0,8"
                                               Foreground="{DynamicResource TextSecondaryBrush}" />
                                    <WrapPanel Margin="0,0,0,12">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,10,4">
                                            <Ellipse Width="8" Height="8" Fill="#10B981" Margin="0,0,3,0" />
                                            <TextBlock Text="Healthy" FontSize="10" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,10,4">
                                            <Ellipse Width="8" Height="8" Fill="#EF4444" Margin="0,0,3,0" />
                                            <TextBlock Text="Cavity" FontSize="10" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,10,4">
                                            <Ellipse Width="8" Height="8" Fill="#3B82F6" Margin="0,0,3,0" />
                                            <TextBlock Text="Filled" FontSize="10" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,10,4">
                                            <Ellipse Width="8" Height="8" Fill="#F59E0B" Margin="0,0,3,0" />
                                            <TextBlock Text="Crown" FontSize="10" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,10,4">
                                            <Ellipse Width="8" Height="8" Fill="#8B5CF6" Margin="0,0,3,0" />
                                            <TextBlock Text="Root Canal" FontSize="10" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,10,4">
                                            <Ellipse Width="8" Height="8" Fill="#6B7280" Margin="0,0,3,0" />
                                            <TextBlock Text="Missing" FontSize="10" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,10,4">
                                            <Ellipse Width="8" Height="8" Fill="#06B6D4" Margin="0,0,3,0" />
                                            <TextBlock Text="Implant" FontSize="10" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,10,4">
                                            <Ellipse Width="8" Height="8" Fill="#EC4899" Margin="0,0,3,0" />
                                            <TextBlock Text="Bridge" FontSize="10" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,10,4">
                                            <Ellipse Width="8" Height="8" Fill="#DC2626" Margin="0,0,3,0" />
                                            <TextBlock Text="Extraction" FontSize="10" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,10,4">
                                            <Ellipse Width="8" Height="8" Fill="#F97316" Margin="0,0,3,0" />
                                            <TextBlock Text="Fractured" FontSize="10" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                                        </StackPanel>
                                    </WrapPanel>

                                    <!-- Upper Jaw -->
                                    <TextBlock Text="UPPER JAW" FontWeight="Bold" FontSize="10" 
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center" Margin="0,0,0,4" />
                                    <ItemsControl ItemsSource="{Binding UpperTeeth}" HorizontalAlignment="Center">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel HorizontalAlignment="Center" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Width="40" Height="42" Margin="1" Cursor="Hand"
                                                        Background="Transparent" BorderThickness="0"
                                                        Click="Tooth_Click" Tag="{Binding}">
                                                    <StackPanel HorizontalAlignment="Center">
                                                        <TextBlock Text="{Binding ToothNumber}" FontSize="8" FontWeight="Bold"
                                                                   HorizontalAlignment="Center" Margin="0,0,0,1"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                                                        <Border Width="26" Height="26" CornerRadius="4"
                                                                BorderThickness="2" 
                                                                BorderBrush="{Binding Color, Converter={StaticResource StringToBrush}}"
                                                                Background="{Binding Color, Converter={StaticResource StringToBrush}, ConverterParameter=0.15}">
                                                            <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                       Foreground="{Binding Color, Converter={StaticResource StringToBrush}}">
                                                                <TextBlock.Text>
                                                                    <Binding Path="Type">
                                                                        <Binding.Converter>
                                                                            <helpers:ToothTypeToIconConverter />
                                                                        </Binding.Converter>
                                                                    </Binding>
                                                                </TextBlock.Text>
                                                            </TextBlock>
                                                        </Border>
                                                    </StackPanel>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- Jaw Separator -->
                                    <Border Height="2" Background="{DynamicResource PrimaryBrush}" 
                                            Margin="8,6" Opacity="0.3" CornerRadius="1" />

                                    <!-- Lower Jaw -->
                                    <TextBlock Text="LOWER JAW" FontWeight="Bold" FontSize="10" 
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center" Margin="0,0,0,4" />
                                    <ItemsControl ItemsSource="{Binding LowerTeeth}" HorizontalAlignment="Center">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel HorizontalAlignment="Center" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Width="40" Height="42" Margin="1" Cursor="Hand"
                                                        Background="Transparent" BorderThickness="0"
                                                        Click="Tooth_Click" Tag="{Binding}">
                                                    <StackPanel HorizontalAlignment="Center">
                                                        <Border Width="26" Height="26" CornerRadius="4"
                                                                BorderThickness="2" 
                                                                BorderBrush="{Binding Color, Converter={StaticResource StringToBrush}}"
                                                                Background="{Binding Color, Converter={StaticResource StringToBrush}, ConverterParameter=0.15}">
                                                            <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                       Foreground="{Binding Color, Converter={StaticResource StringToBrush}}">
                                                                <TextBlock.Text>
                                                                    <Binding Path="Type">
                                                                        <Binding.Converter>
                                                                            <helpers:ToothTypeToIconConverter />
                                                                        </Binding.Converter>
                                                                    </Binding>
                                                                </TextBlock.Text>
                                                            </TextBlock>
                                                        </Border>
                                                        <TextBlock Text="{Binding ToothNumber}" FontSize="8" FontWeight="Bold"
                                                                   HorizontalAlignment="Center" Margin="0,1,0,0"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                                                    </StackPanel>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- Selected Tooth Detail -->
                                    <Border Margin="0,12,0,0" Background="{DynamicResource SurfaceBrush}" 
                                            CornerRadius="8" Padding="12"
                                            Visibility="{Binding SelectedTooth, Converter={StaticResource NullToVis}, FallbackValue=Collapsed}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding SelectedTooth.Name}" FontWeight="SemiBold" FontSize="13"
                                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4" />

                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                <TextBlock Text="Type: " FontSize="11"
                                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                                                <TextBlock Text="{Binding SelectedTooth.Type}" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                                            </StackPanel>

                                            <TextBlock Text="CONDITION" FontSize="10" FontWeight="Bold" Margin="0,0,0,4"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                                            <ComboBox x:Name="ConditionCombo" FontSize="12" Padding="8,6" Margin="0,0,0,10"
                                                      SelectedIndex="0" SelectionChanged="ConditionCombo_Changed">
                                                <ComboBoxItem Content="Healthy" />
                                                <ComboBoxItem Content="Cavity" />
                                                <ComboBoxItem Content="Filled" />
                                                <ComboBoxItem Content="Crown" />
                                                <ComboBoxItem Content="Root Canal" />
                                                <ComboBoxItem Content="Missing" />
                                                <ComboBoxItem Content="Implant" />
                                                <ComboBoxItem Content="Bridge" />
                                                <ComboBoxItem Content="Extraction" />
                                                <ComboBoxItem Content="Fractured" />
                                            </ComboBox>

                                            <TextBlock Text="NOTES" FontSize="10" FontWeight="Bold" Margin="0,0,0,4"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                                            <TextBox Text="{Binding SelectedTooth.Notes, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{DynamicResource ModernTextBoxStyle}" AcceptsReturn="True"
                                                     MinHeight="50" TextWrapping="Wrap" Margin="0,0,0,12" FontSize="12" />

                                            <Button Content="Save Tooth" Command="{Binding SaveToothCommand}"
                                                    Style="{DynamicResource PrimaryButtonStyle}" Padding="10,8" />
                                        </StackPanel>
                                    </Border>

                                    <TextBlock Text="Click a tooth to edit" FontSize="11"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center" Margin="0,12,0,0"
                                               Visibility="{Binding SelectedTooth, Converter={StaticResource NullToVis}, ConverterParameter=Invert}" />
                                </StackPanel>
                            </ScrollViewer>
                        </DockPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- ==================== EDIT FORM ==================== -->
        <ScrollViewer Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}"
                      VerticalScrollBarVisibility="Auto" Padding="20,16">
            <Border Style="{DynamicResource CardStyle}" MaxWidth="580" HorizontalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="{Binding EditingPatient.Id, StringFormat='Patient #{0}', FallbackValue='New Patient'}" 
                               Style="{DynamicResource PageTitleStyle}" Margin="0,0,0,24" />

                    <!-- Photo Section -->
                    <Border Margin="0,0,0,24" Padding="20" CornerRadius="12" 
                            Background="{DynamicResource SurfaceBrush}">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="70" Height="70" CornerRadius="35" 
                                    Background="{DynamicResource BackgroundBrush}"
                                    BorderBrush="{DynamicResource PrimaryBrush}" BorderThickness="2">
                                <Border CornerRadius="35">
                                    <Border.Background>
                                        <ImageBrush ImageSource="{Binding PatientPhoto}" Stretch="UniformToFill" />
                                    </Border.Background>
                                    <TextBlock Text="&#xE722;" FontFamily="Segoe MDL2 Assets" FontSize="32"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextSecondaryBrush}" />
                                </Border>
                            </Border>
                            <StackPanel VerticalAlignment="Center" Margin="20,0,0,0">
                                <TextBlock Text="Patient Photo" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,4"
                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                                <TextBlock Text="JPG, PNG or BMP. Max 5MB." FontSize="12" Margin="0,0,0,12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                                <Button Content="Choose Photo" Command="{Binding ChoosePhotoCommand}"
                                        Style="{DynamicResource SecondaryButtonStyle}" Padding="16,6" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="{local:Localize FullName}" Style="{DynamicResource FormLabelStyle}" />
                    <TextBox Text="{Binding EditingPatient.FullName, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource ModernTextBoxStyle}" Margin="0,0,0,16" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{local:Localize Phone}" Style="{DynamicResource FormLabelStyle}" />
                            <TextBox Text="{Binding EditingPatient.Phone, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource ModernTextBoxStyle}" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{local:Localize DateOfBirth}" Style="{DynamicResource FormLabelStyle}" />
                            <DatePicker SelectedDate="{Binding EditingPatient.DateOfBirth}" FontSize="13" Padding="8,8" />
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{local:Localize Gender}" Style="{DynamicResource FormLabelStyle}" />
                            <ComboBox SelectedItem="{Binding EditingPatient.Gender}" FontSize="13" Padding="8,8">
                                <ComboBoxItem Content="Male" />
                                <ComboBoxItem Content="Female" />
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{local:Localize Email}" Style="{DynamicResource FormLabelStyle}" />
                            <TextBox Text="{Binding EditingPatient.Email, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource ModernTextBoxStyle}" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="{local:Localize Address}" Style="{DynamicResource FormLabelStyle}" Margin="0,16,0,0" />
                    <TextBox Text="{Binding EditingPatient.Address, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource ModernTextBoxStyle}" Margin="0,0,0,16" />

                    <TextBlock Text="{local:Localize Notes}" Style="{DynamicResource FormLabelStyle}" />
                    <TextBox Text="{Binding EditingPatient.Notes, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource ModernTextBoxStyle}" AcceptsReturn="True" 
                             MinHeight="80" TextWrapping="Wrap" Margin="0,0,0,24" />

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="{local:Localize Cancel}" Command="{Binding CancelEditCommand}"
                                Style="{DynamicResource SecondaryButtonStyle}" Margin="0,0,8,0" />
                        <Button Content="{local:Localize Save}" Command="{Binding SaveCommand}"
                                Style="{DynamicResource PrimaryButtonStyle}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</UserControl>
