<UserControl x:Class="ClinicManager.Views.Pages.PatientsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ClinicManager.Localization"
             xmlns:helpers="clr-namespace:ClinicManager.Helpers">

    <UserControl.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid>
        <!-- Main List View -->
        <DockPanel Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
            <!-- Header -->
            <DockPanel DockPanel.Dock="Top" Margin="32,24,32,16">
                <TextBlock Text="{local:Localize Patients}" Style="{DynamicResource PageTitleStyle}" VerticalAlignment="Center" />
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="{local:Localize ExportToPDF}" Command="{Binding ExportPdfCommand}"
                            Style="{DynamicResource SecondaryButtonStyle}" Margin="0,0,8,0" Padding="16,8" />
                    <Button Content="{local:Localize ExportToExcel}" Command="{Binding ExportExcelCommand}"
                            Style="{DynamicResource SecondaryButtonStyle}" Margin="0,0,8,0" Padding="16,8" />
                    <Button Content="{local:Localize AddPatient}" Command="{Binding AddCommand}"
                            Style="{DynamicResource PrimaryButtonStyle}" Padding="16,8" />
                </StackPanel>
            </DockPanel>

            <!-- Search -->
            <Border DockPanel.Dock="Top" Margin="32,0,32,16">
                <TextBox Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                         Style="{DynamicResource ModernTextBoxStyle}"
                         Tag="{local:Localize SearchPatients}" />
            </Border>

            <!-- Data Grid -->
            <Border Margin="32,0,32,24" Style="{DynamicResource CardStyle}" Padding="0">
                <DataGrid ItemsSource="{Binding Patients}" 
                          SelectedItem="{Binding SelectedPatient}"
                          Style="{DynamicResource ModernDataGridStyle}"
                          ColumnHeaderStyle="{DynamicResource ModernDataGridColumnHeaderStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60" />
                        <DataGridTextColumn Header="{local:Localize FullName}" Binding="{Binding FullName}" Width="*" />
                        <DataGridTextColumn Header="{local:Localize Phone}" Binding="{Binding Phone}" Width="140" />
                        <DataGridTextColumn Header="{local:Localize DateOfBirth}" 
                                            Binding="{Binding DateOfBirth, StringFormat='{}{0:yyyy-MM-dd}'}" Width="120" />
                        <DataGridTextColumn Header="{local:Localize Gender}" Binding="{Binding Gender}" Width="80" />
                        <DataGridTextColumn Header="{local:Localize Email}" Binding="{Binding Email}" Width="180" />
                    </DataGrid.Columns>
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="{local:Localize Edit}" Command="{Binding EditCommand}" />
                            <MenuItem Header="{local:Localize Delete}" Command="{Binding DeleteCommand}" />
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                </DataGrid>
            </Border>
        </DockPanel>

        <!-- Edit Form -->
        <ScrollViewer Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}"
                      VerticalScrollBarVisibility="Auto" Padding="32,24">
            <Border Style="{DynamicResource CardStyle}" MaxWidth="600" HorizontalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="{Binding EditingPatient.Id, StringFormat='Patient #{0}', FallbackValue='New Patient'}" 
                               Style="{DynamicResource PageTitleStyle}" Margin="0,0,0,24" />

                    <TextBlock Text="{local:Localize FullName}" Style="{DynamicResource FormLabelStyle}" />
                    <TextBox Text="{Binding EditingPatient.FullName, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource ModernTextBoxStyle}" Margin="0,0,0,16" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{local:Localize Phone}" Style="{DynamicResource FormLabelStyle}" />
                            <TextBox Text="{Binding EditingPatient.Phone, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource ModernTextBoxStyle}" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{local:Localize DateOfBirth}" Style="{DynamicResource FormLabelStyle}" />
                            <DatePicker SelectedDate="{Binding EditingPatient.DateOfBirth}" FontSize="13" Padding="8,8" />
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{local:Localize Gender}" Style="{DynamicResource FormLabelStyle}" />
                            <ComboBox SelectedItem="{Binding EditingPatient.Gender}" FontSize="13" Padding="8,8">
                                <ComboBoxItem Content="Male" />
                                <ComboBoxItem Content="Female" />
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{local:Localize Email}" Style="{DynamicResource FormLabelStyle}" />
                            <TextBox Text="{Binding EditingPatient.Email, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource ModernTextBoxStyle}" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="{local:Localize Address}" Style="{DynamicResource FormLabelStyle}" Margin="0,16,0,0" />
                    <TextBox Text="{Binding EditingPatient.Address, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource ModernTextBoxStyle}" Margin="0,0,0,16" />

                    <TextBlock Text="{local:Localize Notes}" Style="{DynamicResource FormLabelStyle}" />
                    <TextBox Text="{Binding EditingPatient.Notes, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource ModernTextBoxStyle}" AcceptsReturn="True" 
                             MinHeight="80" TextWrapping="Wrap" Margin="0,0,0,24" />

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="{local:Localize Cancel}" Command="{Binding CancelEditCommand}"
                                Style="{DynamicResource SecondaryButtonStyle}" Margin="0,0,8,0" />
                        <Button Content="{local:Localize Save}" Command="{Binding SaveCommand}"
                                Style="{DynamicResource PrimaryButtonStyle}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</UserControl>
