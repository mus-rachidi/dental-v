<UserControl x:Class="ClinicManager.Views.Pages.PatientsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ClinicManager.Localization"
             xmlns:helpers="clr-namespace:ClinicManager.Helpers"
             xmlns:models="clr-namespace:ClinicManager.Models"
             xmlns:controls="clr-namespace:ClinicManager.Views.Controls"
             xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <UserControl.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVis" />
        <helpers:InverseBoolConverter x:Key="InverseBool" />
        <helpers:NullToVisibilityConverter x:Key="NullToVis" />
        <helpers:StringToBrushConverter x:Key="StringToBrush" />
        <helpers:PathToImageSourceConverter x:Key="PathToImage" />
    </UserControl.Resources>

    <Grid>
        <!-- ==================== MAIN VIEW (List + Detail) ==================== -->
        <Grid Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header Bar -->
            <DockPanel Grid.Row="0" Margin="16,12,16,8">
                <TextBlock Text="{local:Localize Patients}" Style="{DynamicResource PageTitleStyle}" VerticalAlignment="Center" />
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="PDF" Command="{Binding ExportPdfCommand}"
                            Style="{DynamicResource SecondaryButtonStyle}" Margin="0,0,6,0" Padding="10,6" FontSize="11" />
                    <Button Content="Excel" Command="{Binding ExportExcelCommand}"
                            Style="{DynamicResource SecondaryButtonStyle}" Margin="0,0,6,0" Padding="10,6" FontSize="11" />
                    <Button Content="{local:Localize AddPatient}" Command="{Binding AddCommand}"
                            Style="{DynamicResource PrimaryButtonStyle}" Padding="12,6" FontSize="11" />
                </StackPanel>
            </DockPanel>

            <!-- Search Bar -->
            <Border Grid.Row="1" Margin="16,0,16,8">
                <TextBox Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                         Style="{DynamicResource ModernTextBoxStyle}"
                         Tag="{local:Localize SearchPatients}" />
            </Border>

            <!-- Content: Patient Grid + Right Detail Panel -->
            <Grid Grid.Row="2" Margin="16,0,16,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="280" />
                </Grid.ColumnDefinitions>

                <!-- Patient Data Grid -->
                <Border Grid.Column="0" Style="{DynamicResource CardStyle}" Padding="0">
                    <DataGrid ItemsSource="{Binding Patients}" 
                              SelectedItem="{Binding SelectedPatient}"
                              Style="{DynamicResource ModernDataGridStyle}"
                              ColumnHeaderStyle="{DynamicResource ModernDataGridColumnHeaderStyle}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50" />
                            <DataGridTextColumn Header="{local:Localize FullName}" Binding="{Binding FullName}" Width="*" />
                            <DataGridTextColumn Header="{local:Localize Phone}" Binding="{Binding Phone}" Width="120" />
                            <DataGridTextColumn Header="{local:Localize DateOfBirth}" 
                                                Binding="{Binding DateOfBirth, StringFormat='{}{0:yyyy-MM-dd}'}" Width="100" />
                            <DataGridTextColumn Header="{local:Localize Gender}" Binding="{Binding Gender}" Width="70" />
                        </DataGrid.Columns>
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="{local:Localize Edit}" Command="{Binding EditCommand}" />
                                <MenuItem Header="{local:Localize Delete}" Command="{Binding DeleteCommand}" />
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                    </DataGrid>
                </Border>

                <!-- ==================== RIGHT PANEL: Patient Detail + Dental Chart ==================== -->
                <Border Grid.Column="2" Style="{DynamicResource CardStyle}" Padding="0">
                    <Grid>
                        <!-- Placeholder when no patient selected -->
                        <StackPanel Visibility="{Binding HasSelection, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"
                                    VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="48"
                                       HorizontalAlignment="Center" Margin="0,0,0,12"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Opacity="0.4" />
                            <TextBlock Text="Select a patient" FontSize="14"
                                       Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" />
                        </StackPanel>

                        <!-- Patient detail when selected -->
                        <DockPanel Visibility="{Binding HasSelection, Converter={StaticResource BoolToVis}}">

                            <!-- Tab Buttons at top -->
                            <Border DockPanel.Dock="Top" Background="{DynamicResource SurfaceBrush}" Padding="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Content="Info" 
                                            Command="{Binding ShowInfoTabCommand}"
                                            Click="InfoTab_Click"
                                            Background="Transparent" BorderThickness="0"
                                            FontWeight="SemiBold" FontSize="10" Padding="4,6" Cursor="Hand"
                                            Foreground="{DynamicResource TextPrimaryBrush}" />
                                    <Button Grid.Column="1" Content="Dental Chart"
                                            Command="{Binding ShowChartTabCommand}"
                                            Click="ChartTab_Click"
                                            Background="Transparent" BorderThickness="0"
                                            FontWeight="SemiBold" FontSize="10" Padding="4,6" Cursor="Hand"
                                            Foreground="{DynamicResource TextPrimaryBrush}" />
                                    <Button Grid.Column="2" Content="X-Ray"
                                            Click="XRayTab_Click"
                                            Background="Transparent" BorderThickness="0"
                                            FontWeight="SemiBold" FontSize="10" Padding="4,6" Cursor="Hand"
                                            Foreground="{DynamicResource TextPrimaryBrush}" />
                                </Grid>
                            </Border>

                            <!-- ===== INFO TAB ===== -->
                            <ScrollViewer x:Name="InfoPanel" VerticalScrollBarVisibility="Auto" Padding="14,10">
                                <StackPanel>
                                    <!-- Patient Photo -->
                                    <Border Width="48" Height="48" 
                                            Background="{DynamicResource SurfaceBrush}" 
                                            HorizontalAlignment="Center" Margin="0,0,0,8"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                        <Border>
                                            <Border.Background>
                                                <ImageBrush ImageSource="{Binding SelectedPatient.PhotoPath, TargetNullValue={x:Null}}" 
                                                            Stretch="UniformToFill" />
                                            </Border.Background>
                                            <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="24"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                                        </Border>
                                    </Border>

                                    <TextBlock Text="{Binding SelectedPatient.FullName}" 
                                               FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,2"
                                               Foreground="{DynamicResource TextPrimaryBrush}" />
                                    <TextBlock Text="{Binding SelectedPatient.Phone}" 
                                               FontSize="11" HorizontalAlignment="Center" Margin="0,0,0,1"
                                               Foreground="{DynamicResource TextSecondaryBrush}" />
                                    <TextBlock Text="{Binding SelectedPatient.Email}" 
                                               FontSize="11" HorizontalAlignment="Center" Margin="0,0,0,10"
                                               Foreground="{DynamicResource TextSecondaryBrush}" />

                                    <!-- Quick Stats -->
                                    <Border Background="{DynamicResource SurfaceBrush}" Padding="8" Margin="0,0,0,8"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding HealthyCount}" FontSize="16" FontWeight="Bold"
                                                           HorizontalAlignment="Center" Foreground="#10B981" />
                                                <TextBlock Text="Healthy" FontSize="9" HorizontalAlignment="Center"
                                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding IssueCount}" FontSize="16" FontWeight="Bold"
                                                           HorizontalAlignment="Center" Foreground="#EF4444" />
                                                <TextBlock Text="Issues" FontSize="9" HorizontalAlignment="Center"
                                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- Info Fields -->
                                    <StackPanel Margin="0,2,0,0">
                                        <TextBlock Text="DATE OF BIRTH" FontSize="9" FontWeight="Bold" Margin="0,0,0,1"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                                        <TextBlock Text="{Binding SelectedPatient.DateOfBirth, StringFormat='{}{0:yyyy-MM-dd}'}" 
                                                   FontSize="11" Margin="0,0,0,6"
                                                   Foreground="{DynamicResource TextPrimaryBrush}" />

                                        <TextBlock Text="GENDER" FontSize="9" FontWeight="Bold" Margin="0,0,0,1"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                                        <TextBlock Text="{Binding SelectedPatient.Gender}" 
                                                   FontSize="11" Margin="0,0,0,6"
                                                   Foreground="{DynamicResource TextPrimaryBrush}" />

                                        <TextBlock Text="ADDRESS" FontSize="9" FontWeight="Bold" Margin="0,0,0,1"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                                        <TextBlock Text="{Binding SelectedPatient.Address, FallbackValue='-'}" 
                                                   FontSize="11" Margin="0,0,0,6" TextWrapping="Wrap"
                                                   Foreground="{DynamicResource TextPrimaryBrush}" />

                                        <TextBlock Text="CIN" FontSize="9" FontWeight="Bold" Margin="0,0,0,1"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                                        <TextBlock Text="{Binding SelectedPatient.CIN, FallbackValue='-'}" 
                                                   FontSize="11" Margin="0,0,0,6"
                                                   Foreground="{DynamicResource TextPrimaryBrush}" />

                                        <TextBlock Text="EMERGENCY CONTACT" FontSize="9" FontWeight="Bold" Margin="0,0,0,1"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                                        <TextBlock Text="{Binding SelectedPatient.EmergencyContact, FallbackValue='-'}" 
                                                   FontSize="11" Margin="0,0,0,6"
                                                   Foreground="{DynamicResource TextPrimaryBrush}" />

                                        <TextBlock Text="CNSS" FontSize="9" FontWeight="Bold" Margin="0,0,0,1"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                                        <TextBlock FontSize="11" Margin="0,0,0,6"
                                                   Foreground="{DynamicResource TextPrimaryBrush}">
                                            <Run Text="{Binding SelectedPatient.CNSSNumber, FallbackValue='-'}" />
                                            <Run Text=" (" />
                                            <Run Text="{Binding SelectedPatient.CNSSCoverageType, FallbackValue='-'}" />
                                            <Run Text=")" />
                                        </TextBlock>

                                        <TextBlock Text="NOTES" FontSize="9" FontWeight="Bold" Margin="0,0,0,1"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                                        <TextBlock Text="{Binding SelectedPatient.Notes, FallbackValue='-'}" 
                                                   FontSize="11" Margin="0,0,0,10" TextWrapping="Wrap"
                                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                                    </StackPanel>

                                    <!-- Action Buttons -->
                                    <Button Content="Edit Patient" Command="{Binding EditCommand}"
                                            Style="{DynamicResource PrimaryButtonStyle}" Margin="0,0,0,8" />
                                    <Button Content="Delete" Command="{Binding DeleteCommand}"
                                            Style="{DynamicResource SecondaryButtonStyle}" 
                                            Foreground="#EF4444" BorderBrush="#EF4444" />
                                </StackPanel>
                            </ScrollViewer>

                            <!-- ===== DENTAL CHART TAB ===== -->
                            <ScrollViewer x:Name="ChartPanel" VerticalScrollBarVisibility="Auto" 
                                          Padding="12,10" Visibility="Collapsed">
                                <StackPanel>
                                    <!-- Legend - Professional horizontal layout -->
                                    <Border Background="{DynamicResource SurfaceBrush}" Padding="12,10" Margin="0,0,0,14"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8">
                                        <WrapPanel>
                                            <Border Width="12" Height="12" Margin="0,0,6,0" CornerRadius="3" Background="#10B981" VerticalAlignment="Center" />
                                            <TextBlock Text="Healthy" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,14,0" VerticalAlignment="Center" />
                                            <Border Width="12" Height="12" Margin="0,0,6,0" CornerRadius="3" Background="#EF4444" VerticalAlignment="Center" />
                                            <TextBlock Text="Cavity" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,14,0" VerticalAlignment="Center" />
                                            <Border Width="12" Height="12" Margin="0,0,6,0" CornerRadius="3" Background="#3B82F6" VerticalAlignment="Center" />
                                            <TextBlock Text="Filled" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,14,0" VerticalAlignment="Center" />
                                            <Border Width="12" Height="12" Margin="0,0,6,0" CornerRadius="3" Background="#F59E0B" VerticalAlignment="Center" />
                                            <TextBlock Text="Crown" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,14,0" VerticalAlignment="Center" />
                                            <Border Width="12" Height="12" Margin="0,0,6,0" CornerRadius="3" Background="#6B7280" VerticalAlignment="Center" />
                                            <TextBlock Text="Missing" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" />
                                        </WrapPanel>
                                    </Border>

                                    <!-- Upper Jaw -->
                                    <TextBlock Text="UPPER JAW (Patient's Right → Left)" FontWeight="SemiBold" FontSize="12" 
                                               Foreground="{DynamicResource PrimaryBrush}"
                                               HorizontalAlignment="Center" Margin="0,0,0,10" />
                                    <Border Background="{DynamicResource SurfaceBrush}" Padding="14,12" Margin="0,0,0,10"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="10">
                                        <ItemsControl ItemsSource="{Binding UpperTeeth}" HorizontalAlignment="Center">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel HorizontalAlignment="Center" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Width="48" Height="60" Margin="3" Cursor="Hand"
                                                            Background="Transparent" BorderThickness="2" BorderBrush="Transparent"
                                                            CornerRadius="6"
                                                            MouseLeftButtonDown="Tooth_Click" Tag="{Binding}"
                                                            ToolTip="{Binding Name}">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="{DynamicResource RowHoverBrush}" />
                                                                    </Trigger>
                                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                                                                        <Setter Property="Background" Value="{DynamicResource PrimaryLightBrush}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding ToothNumber}" FontSize="10" FontWeight="Bold"
                                                                       HorizontalAlignment="Center" Margin="0,0,0,3"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                                                            <controls:ToothShapeControl Width="40" Height="44"
                                                                ToothType="{Binding Type}"
                                                                ConditionColor="{Binding Color, Converter={StaticResource StringToBrush}}" />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Border>

                                    <!-- Jaw Separator -->
                                    <Border Height="2" Background="{DynamicResource PrimaryBrush}" Margin="12,6" Opacity="0.35" />

                                    <!-- Lower Jaw -->
                                    <TextBlock Text="LOWER JAW (Patient's Right → Left)" FontWeight="SemiBold" FontSize="12" 
                                               Foreground="{DynamicResource PrimaryBrush}"
                                               HorizontalAlignment="Center" Margin="0,10,0,10" />
                                    <Border Background="{DynamicResource SurfaceBrush}" Padding="14,12" Margin="0,0,0,14"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="10">
                                        <ItemsControl ItemsSource="{Binding LowerTeeth}" HorizontalAlignment="Center">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel HorizontalAlignment="Center" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Width="48" Height="60" Margin="3" Cursor="Hand"
                                                            Background="Transparent" BorderThickness="2" BorderBrush="Transparent"
                                                            CornerRadius="6"
                                                            MouseLeftButtonDown="Tooth_Click" Tag="{Binding}"
                                                            ToolTip="{Binding Name}">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="{DynamicResource RowHoverBrush}" />
                                                                    </Trigger>
                                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                                                                        <Setter Property="Background" Value="{DynamicResource PrimaryLightBrush}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                            <controls:ToothShapeControl Width="40" Height="44"
                                                                ToothType="{Binding Type}"
                                                                ConditionColor="{Binding Color, Converter={StaticResource StringToBrush}}" />
                                                            <TextBlock Text="{Binding ToothNumber}" FontSize="10" FontWeight="Bold"
                                                                       HorizontalAlignment="Center" Margin="0,3,0,0"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Border>

                                    <!-- Selected Tooth Detail -->
                                    <Border Margin="0,10,0,0" Background="{DynamicResource SurfaceBrush}" 
                                            Padding="16" BorderBrush="{DynamicResource PrimaryBrush}" BorderThickness="1" CornerRadius="10"
                                            Visibility="{Binding SelectedTooth, Converter={StaticResource NullToVis}, FallbackValue=Collapsed}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding SelectedTooth.Name}" FontWeight="SemiBold" FontSize="12"
                                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4" />
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <TextBlock Text="Type: " FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" />
                                                <TextBlock Text="{Binding SelectedTooth.Type}" FontSize="10" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                                            </StackPanel>
                                            <TextBlock Text="CONDITION" FontSize="9" FontWeight="Bold" Margin="0,0,0,2"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                                            <ComboBox x:Name="ConditionCombo" FontSize="11" Padding="6,4" Margin="0,0,0,8"
                                                      SelectedIndex="0" SelectionChanged="ConditionCombo_Changed">
                                                <ComboBoxItem Content="Healthy" />
                                                <ComboBoxItem Content="Cavity" />
                                                <ComboBoxItem Content="Filled" />
                                                <ComboBoxItem Content="Crown" />
                                                <ComboBoxItem Content="Root Canal" />
                                                <ComboBoxItem Content="Missing" />
                                                <ComboBoxItem Content="Implant" />
                                                <ComboBoxItem Content="Bridge" />
                                                <ComboBoxItem Content="Extraction" />
                                                <ComboBoxItem Content="Fractured" />
                                            </ComboBox>
                                            <TextBlock Text="NOTES" FontSize="9" FontWeight="Bold" Margin="0,0,0,2"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                                            <TextBox Text="{Binding SelectedTooth.Notes, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{DynamicResource ModernTextBoxStyle}" AcceptsReturn="True"
                                                     MinHeight="40" TextWrapping="Wrap" Margin="0,0,0,8" FontSize="11" />
                                            <Button Content="Save Tooth" Command="{Binding SaveToothCommand}"
                                                    Style="{DynamicResource PrimaryButtonStyle}" Padding="8,6" FontSize="11" />
                                        </StackPanel>
                                    </Border>

                                    <TextBlock Text="Click a tooth to edit" FontSize="10"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center" Margin="0,6,0,0"
                                               Visibility="{Binding SelectedTooth, Converter={StaticResource NullToVis}, ConverterParameter=Invert}" />
                                </StackPanel>
                            </ScrollViewer>

                            <!-- ===== X-RAY TAB ===== -->
                            <ScrollViewer x:Name="XRayPanel" VerticalScrollBarVisibility="Auto" 
                                          Padding="10,8" Visibility="Collapsed">
                                <StackPanel>
                                    <Button Content="&#xE710;  Add X-Ray" Command="{Binding AddXRayCommand}"
                                            Style="{DynamicResource PrimaryButtonStyle}" 
                                            FontSize="11" Padding="10,6" Margin="0,0,0,10"
                                            HorizontalAlignment="Stretch" />
                                    <ItemsControl ItemsSource="{Binding XRays}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,0,8" Padding="6"
                                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                                        Background="{DynamicResource SurfaceBrush}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="60" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <Border Grid.Column="0" Width="56" Height="56"
                                                                Background="#1a1a2e">
                                                            <Image Source="{Binding ImagePath, Converter={StaticResource PathToImage}}" 
                                                                   Stretch="UniformToFill" />
                                                        </Border>
                                                        <StackPanel Grid.Column="1" Margin="8,0" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Date, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" 
                                                                       FontSize="11" FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                                                            <TextBlock Text="{Binding Notes, FallbackValue='No notes'}" 
                                                                       FontSize="10" TextTrimming="CharacterEllipsis"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                                                        </StackPanel>
                                                        <Button Grid.Column="2" Content="&#xE74D;" 
                                                                Command="{Binding DataContext.DeleteXRayCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                FontFamily="Segoe MDL2 Assets" FontSize="12"
                                                                Background="Transparent" BorderThickness="0"
                                                                Foreground="#EF4444" Cursor="Hand"
                                                                ToolTip="Delete" VerticalAlignment="Center" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Text="No X-rays yet. Click Add X-Ray to upload." FontSize="11"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center" Margin="0,20,0,0"
                                               Visibility="{Binding HasXRays, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}" />
                                </StackPanel>
                            </ScrollViewer>
                        </DockPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- ==================== EDIT FORM ==================== -->
        <ScrollViewer Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}"
                      VerticalScrollBarVisibility="Auto" Padding="16,12">
            <Border Style="{DynamicResource CardStyle}" MaxWidth="540" HorizontalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="{Binding EditingPatient.Id, StringFormat='Patient #{0}', FallbackValue='New Patient'}" 
                               Style="{DynamicResource PageTitleStyle}" Margin="0,0,0,24" />

                    <!-- Photo Section -->
                    <Border Margin="0,0,0,16" Padding="10" 
                            Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="44" Height="44" 
                                    Background="{DynamicResource BackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <Border>
                                    <Border.Background>
                                        <ImageBrush ImageSource="{Binding PatientPhoto}" Stretch="UniformToFill" />
                                    </Border.Background>
                                    <TextBlock Text="&#xE722;" FontFamily="Segoe MDL2 Assets" FontSize="22"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextSecondaryBrush}" />
                                </Border>
                            </Border>
                            <StackPanel VerticalAlignment="Center" Margin="12,0,0,0">
                                <TextBlock Text="Patient Photo" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,2"
                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                                <TextBlock Text="JPG, PNG or BMP. Max 5MB." FontSize="10" Margin="0,0,0,6"
                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                                <Button Content="Choose Photo" Command="{Binding ChoosePhotoCommand}"
                                        Style="{DynamicResource SecondaryButtonStyle}" Padding="10,4" FontSize="11" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="{local:Localize FullName}" Style="{DynamicResource FormLabelStyle}" />
                    <TextBox Text="{Binding EditingPatient.FullName, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource ModernTextBoxStyle}" Margin="0,0,0,16" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{local:Localize Phone}" Style="{DynamicResource FormLabelStyle}" />
                            <TextBox Text="{Binding EditingPatient.Phone, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource ModernTextBoxStyle}" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{local:Localize DateOfBirth}" Style="{DynamicResource FormLabelStyle}" />
                            <DatePicker SelectedDate="{Binding EditingPatient.DateOfBirth}" FontSize="13" Padding="8,8" />
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{local:Localize Gender}" Style="{DynamicResource FormLabelStyle}" />
                            <ComboBox SelectedItem="{Binding EditingPatient.Gender}" FontSize="13" Padding="8,8">
                                <ComboBoxItem Content="Male" />
                                <ComboBoxItem Content="Female" />
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{local:Localize Email}" Style="{DynamicResource FormLabelStyle}" />
                            <TextBox Text="{Binding EditingPatient.Email, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource ModernTextBoxStyle}" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="{local:Localize Address}" Style="{DynamicResource FormLabelStyle}" Margin="0,16,0,0" />
                    <TextBox Text="{Binding EditingPatient.Address, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource ModernTextBoxStyle}" Margin="0,0,0,16" />

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="CIN (Carte d'Identité)" Style="{DynamicResource FormLabelStyle}" />
                            <TextBox Text="{Binding EditingPatient.CIN, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource ModernTextBoxStyle}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Emergency Contact" Style="{DynamicResource FormLabelStyle}" />
                            <TextBox Text="{Binding EditingPatient.EmergencyContact, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource ModernTextBoxStyle}" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Medical History" Style="{DynamicResource SectionTitleStyle}" Margin="0,8,0,8" />
                    <TextBlock Text="Allergies" Style="{DynamicResource FormLabelStyle}" />
                    <TextBox Text="{Binding EditingPatient.Allergies, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource ModernTextBoxStyle}" Margin="0,0,0,8" />
                    <TextBlock Text="Medications" Style="{DynamicResource FormLabelStyle}" />
                    <TextBox Text="{Binding EditingPatient.Medications, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource ModernTextBoxStyle}" Margin="0,0,0,8" />
                    <TextBlock Text="Chronic Diseases" Style="{DynamicResource FormLabelStyle}" />
                    <TextBox Text="{Binding EditingPatient.ChronicDiseases, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource ModernTextBoxStyle}" Margin="0,0,0,16" />

                    <TextBlock Text="CNSS (Sécurité Sociale)" Style="{DynamicResource SectionTitleStyle}" Margin="0,8,0,8" />
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="CNSS Number" Style="{DynamicResource FormLabelStyle}" />
                            <TextBox Text="{Binding EditingPatient.CNSSNumber, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource ModernTextBoxStyle}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Coverage Type" Style="{DynamicResource FormLabelStyle}" />
                            <ComboBox SelectedItem="{Binding EditingPatient.CNSSCoverageType}" FontSize="13" Padding="8,8">
                                <ComboBoxItem Content="" />
                                <ComboBoxItem Content="Assuré" />
                                <ComboBoxItem Content="Ayant droit" />
                                <ComboBoxItem Content="Pensionnaire" />
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="CNSS Registration Date" Style="{DynamicResource FormLabelStyle}" />
                            <DatePicker SelectedDate="{Binding EditingPatient.CNSSRegistrationDate}" FontSize="13" Padding="8,8" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="CNSS Validity Date" Style="{DynamicResource FormLabelStyle}" />
                            <DatePicker SelectedDate="{Binding EditingPatient.CNSSValidityDate}" FontSize="13" Padding="8,8" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="{local:Localize Notes}" Style="{DynamicResource FormLabelStyle}" />
                    <TextBox Text="{Binding EditingPatient.Notes, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource ModernTextBoxStyle}" AcceptsReturn="True" 
                             MinHeight="80" TextWrapping="Wrap" Margin="0,0,0,24" />

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="{local:Localize Cancel}" Command="{Binding CancelEditCommand}"
                                Style="{DynamicResource SecondaryButtonStyle}" Margin="0,0,8,0" />
                        <Button Content="{local:Localize Save}" Command="{Binding SaveCommand}"
                                Style="{DynamicResource PrimaryButtonStyle}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</UserControl>
