<UserControl x:Class="ClinicManager.Views.Pages.AppointmentsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ClinicManager.Localization"
             xmlns:helpers="clr-namespace:ClinicManager.Helpers">

    <UserControl.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid>
        <!-- Main List + Calendar -->
        <Grid Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Modern Calendar -->
            <Border Grid.Column="0" Margin="16,12,8,12" Style="{DynamicResource CardStyle}" Padding="12">
                <StackPanel>
                    <TextBlock Text="{local:Localize Appointments}" Style="{DynamicResource SectionTitleStyle}" Margin="0,0,0,12" />
                    <Calendar SelectedDate="{Binding CalendarDate, Mode=TwoWay}"
                              DisplayDate="{Binding FilterFrom}"
                              BorderThickness="0" Background="Transparent"
                              FontSize="13" FontFamily="Segoe UI" />
                    <Button Content="{local:Localize TodayAppointments}" Command="{Binding ShowTodayCommand}"
                            Style="{DynamicResource SecondaryButtonStyle}" Margin="0,12,0,0" Padding="12,8" />
                </StackPanel>
            </Border>

            <!-- Right: Toolbar + Grid -->
            <DockPanel Grid.Column="1">
                <DockPanel DockPanel.Dock="Top" Margin="8,12,16,8">
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <TextBlock Text="{local:Localize From}" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                        <DatePicker SelectedDate="{Binding FilterFrom}" Width="120" />
                        <TextBlock Text="{local:Localize To}" VerticalAlignment="Center" Margin="12,0,6,0" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                        <DatePicker SelectedDate="{Binding FilterTo}" Width="120" />
                        <Button Content="{local:Localize Apply}" Command="{Binding FilterCommand}"
                                Style="{DynamicResource PrimaryButtonStyle}" Margin="12,0,8,0" Padding="14,6" />
                        <Button Content="{local:Localize AddAppointment}" Command="{Binding AddCommand}"
                                Style="{DynamicResource PrimaryButtonStyle}" Padding="14,6" />
                    </StackPanel>
                </DockPanel>

            <!-- Grid -->
            <Border Margin="8,0,16,12" Style="{DynamicResource CardStyle}" Padding="0">
                <DataGrid ItemsSource="{Binding Appointments}" 
                          SelectedItem="{Binding SelectedAppointment}"
                          Style="{DynamicResource ModernDataGridStyle}"
                          ColumnHeaderStyle="{DynamicResource ModernDataGridColumnHeaderStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50" />
                        <DataGridTextColumn Header="{local:Localize PatientName}" Binding="{Binding Patient.FullName}" Width="*" />
                        <DataGridTextColumn Header="{local:Localize Doctor}" Binding="{Binding DoctorName}" Width="150" />
                        <DataGridTextColumn Header="{local:Localize Date}" 
                                            Binding="{Binding Date, StringFormat='{}{0:yyyy-MM-dd}'}" Width="110" />
                        <DataGridTextColumn Header="{local:Localize Time}" 
                                            Binding="{Binding Time, StringFormat='{}{0:hh\\:mm}'}" Width="80" />
                        <DataGridTextColumn Header="{local:Localize Duration}" 
                                            Binding="{Binding DurationMinutes, StringFormat='{}{0} min'}" Width="80" />
                        <DataGridTextColumn Header="{local:Localize Status}" Binding="{Binding Status}" Width="100" />
                    </DataGrid.Columns>
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="{local:Localize Edit}" Command="{Binding EditCommand}" />
                            <MenuItem Header="{local:Localize Completed}" Command="{Binding MarkCompletedCommand}" />
                            <MenuItem Header="{local:Localize Cancelled}" Command="{Binding MarkCancelledCommand}" />
                            <Separator />
                            <MenuItem Header="{local:Localize Delete}" Command="{Binding DeleteCommand}" />
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                </DataGrid>
            </Border>
            </DockPanel>
        </Grid>

        <!-- Edit Form -->
        <ScrollViewer Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}"
                      VerticalScrollBarVisibility="Auto" Padding="32,24">
            <Border Style="{DynamicResource CardStyle}" MaxWidth="640" HorizontalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="{local:Localize AddAppointment}" 
                               Style="{DynamicResource PageTitleStyle}" Margin="0,0,0,16" />

                    <TextBlock Text="{local:Localize SelectPatient}" Style="{DynamicResource FormLabelStyle}" />
                    <ComboBox ItemsSource="{Binding AvailablePatients}" 
                              SelectedValue="{Binding EditPatientId}" SelectedValuePath="Id"
                              DisplayMemberPath="FullName" FontSize="13" Padding="10" Margin="0,0,0,16" />

                    <TextBlock Text="{local:Localize Doctor}" Style="{DynamicResource FormLabelStyle}" />
                    <TextBox Text="{Binding EditDoctor, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource ModernTextBoxStyle}" Margin="0,0,0,16" />

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{local:Localize Date}" Style="{DynamicResource FormLabelStyle}" />
                            <DatePicker SelectedDate="{Binding EditDate}" FontSize="13" Padding="8" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{local:Localize Time}" Style="{DynamicResource FormLabelStyle}" />
                            <TextBox Text="{Binding EditTimeString, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource ModernTextBoxStyle}" MaxLength="5"
                                     ToolTip="HH:mm (e.g. 09:30)" />
                        </StackPanel>

                        <StackPanel Grid.Column="4">
                            <TextBlock Text="{local:Localize Duration}" Style="{DynamicResource FormLabelStyle}" />
                            <ComboBox SelectedItem="{Binding EditDuration}" FontSize="13" Padding="10">
                                <sys:Int32 xmlns:sys="clr-namespace:System;assembly=mscorlib">15</sys:Int32>
                                <sys:Int32 xmlns:sys="clr-namespace:System;assembly=mscorlib">30</sys:Int32>
                                <sys:Int32 xmlns:sys="clr-namespace:System;assembly=mscorlib">45</sys:Int32>
                                <sys:Int32 xmlns:sys="clr-namespace:System;assembly=mscorlib">60</sys:Int32>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="{local:Localize Notes}" Style="{DynamicResource FormLabelStyle}" />
                    <TextBox Text="{Binding EditNotes, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource ModernTextBoxStyle}" AcceptsReturn="True" 
                             MinHeight="60" TextWrapping="Wrap" Margin="0,0,0,24" />

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="{local:Localize Cancel}" Command="{Binding CancelEditCommand}"
                                Style="{DynamicResource SecondaryButtonStyle}" Margin="0,0,8,0" />
                        <Button Content="{local:Localize Save}" Command="{Binding SaveCommand}"
                                Style="{DynamicResource PrimaryButtonStyle}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</UserControl>
