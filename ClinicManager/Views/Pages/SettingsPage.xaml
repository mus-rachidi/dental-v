<UserControl x:Class="ClinicManager.Views.Pages.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:local="clr-namespace:ClinicManager.Localization">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel MaxWidth="720" Margin="36,28,36,36">
            <TextBlock Text="{local:Localize Settings}" Style="{DynamicResource PageTitleStyle}" Margin="0,0,0,28" />

            <!-- General Settings -->
            <Border Style="{DynamicResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{local:Localize General}" Style="{DynamicResource SectionTitleStyle}" Margin="0,0,0,20" />

                    <TextBlock Text="{local:Localize ClinicName}" Style="{DynamicResource FormLabelStyle}" />
                    <TextBox Text="{Binding ClinicName, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource ModernTextBoxStyle}" Margin="0,0,0,16" />

                    <TextBlock Text="{local:Localize ClinicAddress}" Style="{DynamicResource FormLabelStyle}" />
                    <TextBox Text="{Binding ClinicAddress, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource ModernTextBoxStyle}" Margin="0,0,0,16" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{local:Localize ClinicPhone}" Style="{DynamicResource FormLabelStyle}" />
                            <TextBox Text="{Binding ClinicPhone, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource ModernTextBoxStyle}" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{local:Localize DefaultDoctor}" Style="{DynamicResource FormLabelStyle}" />
                            <TextBox Text="{Binding DefaultDoctor, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource ModernTextBoxStyle}" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Appearance -->
            <Border Style="{DynamicResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Appearance" Style="{DynamicResource SectionTitleStyle}" Margin="0,0,0,20" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{local:Localize Language}" Style="{DynamicResource FormLabelStyle}" />
                            <ComboBox x:Name="LanguageCombo" SelectedIndex="{Binding SelectedLanguageIndex}" 
                                      FontSize="13" Padding="10" SelectionChanged="LanguageCombo_Changed">
                                <ComboBoxItem Content="English" />
                                <ComboBoxItem Content="Français" />
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{local:Localize Theme}" Style="{DynamicResource FormLabelStyle}" />
                            <ComboBox x:Name="ThemeCombo" SelectedIndex="{Binding SelectedThemeIndex}" 
                                      FontSize="13" Padding="10" SelectionChanged="ThemeCombo_Changed">
                                <ComboBoxItem Content="Light" />
                                <ComboBoxItem Content="Dark" />
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <CheckBox Content="{local:Localize MinimizeToTray}" IsChecked="{Binding MinimizeToTray}" 
                              Margin="0,20,0,0" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}" />
                </StackPanel>
            </Border>

            <!-- Backup Settings -->
            <Border Style="{DynamicResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{local:Localize BackupSettings}" Style="{DynamicResource SectionTitleStyle}" Margin="0,0,0,20" />

                    <CheckBox Content="{local:Localize AutoBackup}" IsChecked="{Binding AutoBackup}" 
                              FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,16" />

                    <StackPanel Orientation="Horizontal">
                        <Button Content="{local:Localize BackupNow}" Command="{Binding BackupNowCommand}"
                                Style="{DynamicResource PrimaryButtonStyle}" Padding="20,10" Margin="0,0,10,0" />
                        <Button Content="{local:Localize RestoreBackup}" Command="{Binding RestoreBackupCommand}"
                                Style="{DynamicResource SecondaryButtonStyle}" Padding="20,10" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- License Info -->
            <Border Style="{DynamicResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{local:Localize LicenseInfo}" Style="{DynamicResource SectionTitleStyle}" Margin="0,0,0,20" />

                    <TextBlock Text="MACHINE ID" Style="{DynamicResource FormLabelStyle}" FontSize="11" FontWeight="Bold" />
                    <TextBox Text="{Binding MachineId, Mode=OneWay}" Style="{DynamicResource ModernTextBoxStyle}" 
                             IsReadOnly="True" Margin="0,0,0,16" FontFamily="Cascadia Code, Consolas" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{DynamicResource FormLabelStyle}">
                                <Run Text="{local:Localize LicensedTo}" />
                            </TextBlock>
                            <TextBlock Text="{Binding LicensedTo, Mode=OneWay}" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{DynamicResource FormLabelStyle}">
                                <Run Text="{local:Localize ActivationDate}" />
                            </TextBlock>
                            <TextBlock Text="{Binding ActivationDate, Mode=OneWay}" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Save Button -->
            <Button Content="{local:Localize Save}" Command="{Binding SaveCommand}"
                    Style="{DynamicResource PrimaryButtonStyle}" HorizontalAlignment="Right" Padding="36,12" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
