<UserControl x:Class="ClinicManager.Views.Pages.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:local="clr-namespace:ClinicManager.Localization">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel MaxWidth="580" Margin="16,12,16,16">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="22"
                           Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" Margin="0,0,10,0" />
                <TextBlock Text="{local:Localize Settings}" Style="{DynamicResource PageTitleStyle}" />
            </StackPanel>

            <!-- General Settings -->
            <Border Style="{DynamicResource CardStyle}" Margin="0,0,0,10">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Width="26" Height="26" CornerRadius="6" Margin="0,0,10,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#0891B2" Offset="0" />
                                    <GradientStop Color="#14B8A6" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="&#xE7FC;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="{local:Localize General}" Style="{DynamicResource SectionTitleStyle}" VerticalAlignment="Center" />
                    </StackPanel>

                    <TextBlock Text="{local:Localize ClinicName}" Style="{DynamicResource FormLabelStyle}" />
                    <TextBox Text="{Binding ClinicName, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource ModernTextBoxStyle}" Margin="0,0,0,14" />

                    <TextBlock Text="{local:Localize ClinicAddress}" Style="{DynamicResource FormLabelStyle}" />
                    <TextBox Text="{Binding ClinicAddress, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource ModernTextBoxStyle}" Margin="0,0,0,14" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{local:Localize ClinicPhone}" Style="{DynamicResource FormLabelStyle}" />
                            <TextBox Text="{Binding ClinicPhone, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource ModernTextBoxStyle}" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{local:Localize DefaultDoctor}" Style="{DynamicResource FormLabelStyle}" />
                            <TextBox Text="{Binding DefaultDoctor, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource ModernTextBoxStyle}" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Appearance -->
            <Border Style="{DynamicResource CardStyle}" Margin="0,0,0,10">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Width="26" Height="26" CornerRadius="6" Margin="0,0,10,0"
                                Background="{DynamicResource AccentBrush}">
                            <TextBlock Text="&#xE790;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="Appearance" Style="{DynamicResource SectionTitleStyle}" VerticalAlignment="Center" />
                    </StackPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{local:Localize Language}" Style="{DynamicResource FormLabelStyle}" />
                            <ComboBox x:Name="LanguageCombo" SelectedIndex="{Binding SelectedLanguageIndex}" 
                                      FontSize="13" Padding="10" SelectionChanged="LanguageCombo_Changed">
                                <ComboBoxItem Content="English" />
                                <ComboBoxItem Content="Français" />
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{local:Localize Theme}" Style="{DynamicResource FormLabelStyle}" />
                            <ComboBox x:Name="ThemeCombo" SelectedIndex="{Binding SelectedThemeIndex}" 
                                      FontSize="13" Padding="10" SelectionChanged="ThemeCombo_Changed">
                                <ComboBoxItem Content="Light" />
                                <ComboBoxItem Content="Dark" />
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <CheckBox Content="{local:Localize MinimizeToTray}" IsChecked="{Binding MinimizeToTray}" 
                              Margin="0,18,0,0" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}" />
                </StackPanel>
            </Border>

            <!-- Backup Settings -->
            <Border Style="{DynamicResource CardStyle}" Margin="0,0,0,10">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Width="26" Height="26" CornerRadius="6" Margin="0,0,10,0"
                                Background="{DynamicResource WarningBrush}">
                            <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="{local:Localize BackupSettings}" Style="{DynamicResource SectionTitleStyle}" VerticalAlignment="Center" />
                    </StackPanel>

                    <CheckBox Content="{local:Localize AutoBackup}" IsChecked="{Binding AutoBackup}" 
                              FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,14" />

                    <StackPanel Orientation="Horizontal">
                        <Button Content="{local:Localize BackupNow}" Command="{Binding BackupNowCommand}"
                                Style="{DynamicResource PrimaryButtonStyle}" Padding="20,10" Margin="0,0,10,0" />
                        <Button Content="{local:Localize RestoreBackup}" Command="{Binding RestoreBackupCommand}"
                                Style="{DynamicResource SecondaryButtonStyle}" Padding="20,10" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- License Info -->
            <Border Style="{DynamicResource CardStyle}" Margin="0,0,0,10">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Width="26" Height="26" CornerRadius="6" Margin="0,0,10,0"
                                Background="{DynamicResource SuccessBrush}">
                            <TextBlock Text="&#xE8D7;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="{local:Localize LicenseInfo}" Style="{DynamicResource SectionTitleStyle}" VerticalAlignment="Center" />
                    </StackPanel>

                    <TextBlock Text="MACHINE ID" Style="{DynamicResource FormLabelStyle}" FontSize="10.5" FontWeight="Bold" />
                    <TextBox Text="{Binding MachineId, Mode=OneWay}" Style="{DynamicResource ModernTextBoxStyle}" 
                             IsReadOnly="True" Margin="0,0,0,14" FontFamily="Cascadia Code, Consolas" FontSize="12" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{DynamicResource FormLabelStyle}">
                                <Run Text="{local:Localize LicensedTo}" />
                            </TextBlock>
                            <TextBlock Text="{Binding LicensedTo, Mode=OneWay}" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{DynamicResource FormLabelStyle}">
                                <Run Text="{local:Localize ActivationDate}" />
                            </TextBlock>
                            <TextBlock Text="{Binding ActivationDate, Mode=OneWay}" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Save -->
            <Button Content="{local:Localize Save}" Command="{Binding SaveCommand}"
                    Style="{DynamicResource PrimaryButtonStyle}" HorizontalAlignment="Right" Padding="36,12" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
