<Window x:Class="ClinicManager.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:ClinicManager.Helpers"
        Title="ClinicPro - Login"
        Height="420" Width="400" MinHeight="380" MinWidth="360"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{DynamicResource BackgroundBrush}"
        Icon="pack://application:,,,/ClinicManager;component/Resources/Icons/app.ico">

    <Window.Resources>
        <helpers:InverseBoolConverter x:Key="InverseBool" />
        <helpers:StringToVisibilityConverter x:Key="StringToVis" />
    </Window.Resources>

    <Grid>
        <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="12"
                Margin="24" Padding="32,28"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="48"
                           Foreground="{DynamicResource PrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,8" />
                <TextBlock Text="ClinicPro" FontSize="22" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,4" />
                <TextBlock Text="Sign in to continue" FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,24" />

                <TextBlock Text="Username" Style="{DynamicResource FormLabelStyle}" />
                <TextBox x:Name="UsernameBox" Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         Style="{DynamicResource ModernTextBoxStyle}" Margin="0,4,0,16"
                         IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBool}}" />

                <TextBlock Text="Password" Style="{DynamicResource FormLabelStyle}" />
                <PasswordBox x:Name="PasswordBox" Margin="0,4,0,8"
                             Style="{DynamicResource ModernPasswordBoxStyle}"
                             PasswordChanged="PasswordBox_PasswordChanged"
                             IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBool}}" />

                <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource DangerBrush}"
                           FontSize="12" TextWrapping="Wrap" Margin="0,0,0,12"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVis}}" />

                <Button Content="Sign In" Command="{Binding LoginCommand}"
                        Style="{DynamicResource PrimaryButtonStyle}" Padding="16,12" FontSize="14"
                        IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBool}}" />

                <TextBlock Text="Default: admin / Admin@123" FontSize="10"
                           Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"
                           Margin="0,16,0,0" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
