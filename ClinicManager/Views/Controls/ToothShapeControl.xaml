<UserControl x:Class="ClinicManager.Views.Controls.ToothShapeControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Anatomically accurate tooth shapes - clinical buccal/frontal view -->
    <Viewbox x:Name="ViewboxRoot" Stretch="Uniform" Width="40" Height="48">
        <Canvas Width="32" Height="48">
            <!-- Incisor: flat incisal edge, rectangular crown, cervical constriction -->
            <Path x:Name="IncisorPath" Visibility="Collapsed"
                  Data="M 4,0 L 12,0 L 14,2 L 15,6 L 15,10 L 14,12 L 14,46 L 4,46 L 4,12 L 3,10 L 3,6 L 4,2 Z"
                  StrokeThickness="1.2" StrokeLineJoin="Round" />
            <!-- Canine: pointed cusp, elongated crown -->
            <Path x:Name="CaninePath" Visibility="Collapsed"
                  Data="M 4,8 L 8,0 L 16,0 L 20,8 L 19,46 L 5,46 L 4,8 Z"
                  StrokeThickness="1.2" StrokeLineJoin="Round" />
            <!-- Premolar: 2 cusps (bicuspid), rounded occlusal -->
            <Path x:Name="PremolarPath" Visibility="Collapsed"
                  Data="M 2,8 Q 5,2 8,6 Q 11,2 14,8 L 15,46 L 1,46 L 2,8 Z"
                  StrokeThickness="1.2" StrokeLineJoin="Round" />
            <!-- Molar: 4 cusps, wider crown, rectangular -->
            <Path x:Name="MolarPath" Visibility="Collapsed"
                  Data="M 0,10 Q 3,2 6,6 Q 9,2 12,6 Q 15,2 18,10 L 19,46 L 0,46 L 0,10 Z"
                  StrokeThickness="1.2" StrokeLineJoin="Round" />
            <!-- Wisdom: molar-like, slightly narrower -->
            <Path x:Name="WisdomPath" Visibility="Collapsed"
                  Data="M 2,8 Q 5,2 8,5 Q 11,2 14,8 L 15,46 L 1,46 L 2,8 Z"
                  StrokeThickness="1.2" StrokeLineJoin="Round" />
        </Canvas>
    </Viewbox>
</UserControl>
